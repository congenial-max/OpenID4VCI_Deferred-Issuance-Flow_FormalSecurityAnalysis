lemma exec_full_honest_deferred_flow:
  exists-trace
  "∃ Wid CI sid pkH sig #f.
    (((((((Finish( Wid, CI, sid ) @ #f) ∧
          (Wallet_Accepted_Credential( Wid, CI, sid, pkH, sig ) @ #f)) ∧
         (¬(∃ #r. Reveal_CI( CI ) @ #r))) ∧
        (¬(∃ p #r. Reveal_HolderKey( Wid, p ) @ #r))) ∧
       (¬(∃ p #r. Reveal_WalletEncKey( Wid, p ) @ #r))) ∧
      (¬(∃ at #r. Reveal_StoredAT( Wid, CI, at ) @ #r))) ∧
     (¬(∃ p #r. Reveal_DPoPKey( Wid, p ) @ #r))) ∧
    (¬(∃ t #r. Reveal_TxId( Wid, CI, t ) @ #r))"
/*
guarded formula characterizing all satisfying traces:
"∃ Wid CI sid pkH sig #f.
  (Finish( Wid, CI, sid ) @ #f) ∧
  (Wallet_Accepted_Credential( Wid, CI, sid, pkH, sig ) @ #f)
 ∧
  (∀ #r. (Reveal_CI( CI ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_HolderKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_WalletEncKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ at #r. (Reveal_StoredAT( Wid, CI, at ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_DPoPKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ t #r. (Reveal_TxId( Wid, CI, t ) @ #r) ⇒ ⊥)"
*/
simplify
solve( W_DeferredSent_V3( $Wid, $CI, $AS, ~sid, AT, ~skH, pkH, ~skE_W,
                          pkE_W, ~skB, pkB, ~skDPoP, pkDPoP, tid
       ) ▶₀ #f )
  case Wallet_Send_Deferred_Req___VARIANT_1
  solve( !Ltk_CI( $CI, ~ltkCI ) ▶₂ #f )
    case Register_CI
    solve( !KU( penc(<'cred-resp', 
                      sign(<'credential', $CI, 'PII-dataset', pk(~skH)>, ~ltkCI)>,
                     pk(~skE_W), rRespEnc)
           ) @ #vk )
      case CI_Deferred_Endpoint_V3___VARIANT_4
      solve( !KU( penc(<'202-deferred', tid>, pk(~skE_W), rRespEnc.1)
             ) @ #vk.1 )
        case CI_Credential_Endpoint_Defer___VARIANT_4
        solve( !KU( penc(<'def-req-v3', 
                          aTokenV3(~atSecret, pk(~skDPoP), pk(~skH), $CI, $AS), 
                          sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP), jti_d.1, 
                                aTokenV3(~atSecret, pk(~skDPoP), pk(~skH), $CI, $AS)>,
                               ~skDPoP), 
                          ~tid_ci.1, 'crypt-resp', pk(~skE_W), 'tid-bind-sig', 
                          sign(<'oid4vci-tid-bind', $CI, ~tid_ci.1, h(pk(~skE_W))>, skB_x)>,
                         pk(~skR_CI), rEnc.2)
               ) @ #vk.4 )
          case Wallet_Send_Deferred_Req___VARIANT_1
          solve( !KU( penc(<'credential-req-v3', 
                            aTokenV3(~atSecret, pk(~skDPoP), pk(~skH), $CI, $AS), 
                            sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), jti_c.1, 
                                  aTokenV3(~atSecret, pk(~skDPoP), pk(~skH), $CI, $AS)>,
                                 ~skDPoP), 
                            pk(~skH), 
                            sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, iat.1>, ~skH), 
                            'crypt-resp', pk(~skE_W), 'tid-bind', pk(~skB)>,
                           pk(~skR_CI), rEnc.2)
                 ) @ #vk.7 )
            case Wallet_Send_Credential_Req___VARIANT_1
            SOLVED // trace found
          qed
        qed
      qed
    qed
  qed
qed

lemma P50_holder_binding_preserved [heuristic={P50_tactic}]:
  all-traces
  "∀ CI pkH AT tid #i.
    (((CredIssued_For_PkH( CI, pkH, AT, tid ) @ #i) ∧
      (¬(∃ #r. Reveal_CI( CI ) @ #r))) ∧
     (¬(∃ #r. Reveal_CI_ReqEncKey( CI ) @ #r))) ⇒
    (((∃ Wid s #g. (WalletGen_HolderKey( Wid, s, pkH ) @ #g) ∧ (#g < #i)) ∨
      (∃ Wid #r. (Reveal_HolderKey( Wid, pkH ) @ #r) ∧ (#r < #i))) ∨
     (∃ #k. (!KU( pkH ) @ #k) ∧ (#k < #i)))"
/*
guarded formula characterizing all counter-examples:
"∃ CI pkH AT tid #i.
  (CredIssued_For_PkH( CI, pkH, AT, tid ) @ #i)
 ∧
  (∀ #r. (Reveal_CI( CI ) @ #r) ⇒ ⊥) ∧
  (∀ #r. (Reveal_CI_ReqEncKey( CI ) @ #r) ⇒ ⊥) ∧
  (∀ Wid s #g. (WalletGen_HolderKey( Wid, s, pkH ) @ #g) ⇒ ¬(#g < #i)) ∧
  (∀ Wid #r. (Reveal_HolderKey( Wid, pkH ) @ #r) ⇒ ¬(#r < #i)) ∧
  (∀ #k. (!KU( pkH ) @ #k) ⇒ ¬(#k < #i))"
*/
simplify
solve( CredIssued_For_PkH( CI, pkH, AT, tid ) @ #i )
  case CI_Deferred_Endpoint_V3___VARIANT_4
  solve( !KU( penc(<'def-req-v3', AT, 
                    sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(skDPoP_x), jti_d, AT>,
                         skDPoP_x), 
                    tid, 'crypt-resp', pkE_new, 'tid-bind-sig', 
                    sign(<'oid4vci-tid-bind', $CI, tid, h(pkE_new)>, skB_x)>,
                   pk(~skR_CI), rEnc)
         ) @ #vk.2 )
    case Wallet_Send_Deferred_Req___VARIANT_1
    solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
      case CI_Publish_RequestEncKey
      solve( !CI_PendingTx_Fixed( $CI, tid,
                                  aTokenV3(~atSecret, pk(~skDPoP), pk(~skH), $CI, $AS), $AS.1, $Wid_at,
                                  pk(~skDPoP), pkH, pk(~skB)
             ) ▶₂ #i )
        case CI_Credential_Endpoint_Defer___VARIANT_4
        by contradiction /* from formulas */
      qed
    qed
  next
    case c_penc
    solve( !KU( pk(~skR_CI) ) @ #vk.4 )
      case CI_Publish_RequestEncKey
      solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
        case CI_Publish_RequestEncKey
        solve( !CI_PendingTx_Fixed( $CI, tid, AT, $AS, $Wid_at, pk(skDPoP_x),
                                    pkH, pk(skB_x)
               ) ▶₂ #i )
          case CI_Credential_Endpoint_Defer___VARIANT_4
          by contradiction /* from formulas */
        qed
      qed
    next
      case Register_CI
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case Wallet_Send_Credential_Req___VARIANT_1_case_1
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case Wallet_Send_Credential_Req___VARIANT_1_case_2
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case Wallet_Send_Credential_Req___VARIANT_1_case_3
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case Wallet_Send_Deferred_Req___VARIANT_1
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case c_pk
      solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
        case CI_Publish_RequestEncKey
        by contradiction /* from formulas */
      qed
    qed
  qed
qed

lemma c2prime_attack_blocked_v3:
  all-traces
  "∀ CI AS WidA WidB pkH_A pkH_B cred AT tid pkE_Adv pkB_Adv pkD sidA sidB
     #wA #wB #i #r_at #r_dp #r_h.
    ((((((((((((Wallet_Sent_Cred_Req( WidA, CI, sidA, pkH_A, AT ) @ #wA) ∧
               (WalletGen_HolderKey( WidB, sidB, pkH_B ) @ #wB)) ∧
              (CI_Issued_Credential_Fixed( CI, AS, WidA, pkH_B, cred, AT, tid, pkE_Adv,
                                           pkB_Adv
               ) @ #i)) ∧
             (Reveal_StoredAT( WidA, CI, AT ) @ #r_at)) ∧
            (Reveal_DPoPKey( WidA, pkD ) @ #r_dp)) ∧
           (Reveal_HolderKey( WidB, pkH_B ) @ #r_h)) ∧
          (¬(WidA = WidB))) ∧
         (¬(∃ #r. Reveal_CI( CI ) @ #r))) ∧
        (¬(∃ #r. Reveal_CI_ReqEncKey( CI ) @ #r))) ∧
       (¬(∃ p #r. Reveal_WalletBindKey( WidA, p ) @ #r))) ∧
      (¬(∃ p #r. Reveal_HolderKey( WidA, p ) @ #r))) ∧
     (¬(∃ p #r. Reveal_WalletEncKey( WidA, p ) @ #r))) ⇒
    (¬(∃ #k. K( cred ) @ #k))"
/*
guarded formula characterizing all counter-examples:
"∃ CI AS WidA WidB pkH_A pkH_B cred AT tid pkE_Adv pkB_Adv pkD sidA sidB
   #wA #wB #i #r_at #r_dp #r_h.
  (Wallet_Sent_Cred_Req( WidA, CI, sidA, pkH_A, AT ) @ #wA) ∧
  (WalletGen_HolderKey( WidB, sidB, pkH_B ) @ #wB) ∧
  (CI_Issued_Credential_Fixed( CI, AS, WidA, pkH_B, cred, AT, tid, pkE_Adv,
                               pkB_Adv
   ) @ #i) ∧
  (Reveal_StoredAT( WidA, CI, AT ) @ #r_at) ∧
  (Reveal_DPoPKey( WidA, pkD ) @ #r_dp) ∧
  (Reveal_HolderKey( WidB, pkH_B ) @ #r_h)
 ∧
  (¬(WidA = WidB)) ∧
  (∀ #r. (Reveal_CI( CI ) @ #r) ⇒ ⊥) ∧
  (∀ #r. (Reveal_CI_ReqEncKey( CI ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_WalletBindKey( WidA, p ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_HolderKey( WidA, p ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_WalletEncKey( WidA, p ) @ #r) ⇒ ⊥) ∧
  (∃ #k. (K( cred ) @ #k))"
*/
simplify
solve( W_HasAT_V3( $Wid, $CI, $AS, ~sid, AT, ~skDPoP, pkDPoP, ~skH, pkH_A
       ) ▶₀ #wA )
  case Wallet_Get_AT
  solve( !CI_ReqEncPk( $CI, pkR_CI ) ▶₁ #wA )
    case CI_Publish_RequestEncKey
    solve( !StoredAT( $Wid, $CI,
                      aTokenV3(~atSecret, pk(~skDPoP), pk(~skH), $CI, $AS)
           ) ▶₀ #r_at )
      case Wallet_Get_AT
      solve( !StoredDPoPKey( $Wid, ~skDPoP.1, pkD ) ▶₀ #r_dp )
        case Wallet_Get_AT
        solve( !StoredHolderKey( $Wid.1, ~skH.1, pk(~skH.2) ) ▶₀ #r_h )
          case Wallet_Get_AT
          solve( CI_Issued_Credential_Fixed( $CI, AS.4, $Wid, pk(~skH.1), cred,
                                             aTokenV3(~atSecret, pk(~skDPoP), pk(~skH), $CI, $AS), tid,
                                             pkE_Adv, pkB_Adv
                 ) @ #i )
            case CI_Deferred_Endpoint_V3___VARIANT_4
            solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
              case CI_Publish_RequestEncKey
              solve( !CI_PendingTx_Fixed( $CI, tid,
                                          aTokenV3(~atSecret, pk(~skDPoP), pk(~skH), $CI, $AS), $AS.1, $Wid,
                                          pk(skDPoP_x), pk(~skH.1), pk(skB_x)
                     ) ▶₂ #i )
                case CI_Credential_Endpoint_Defer___VARIANT_4
                by contradiction /* from formulas */
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

