// ============================================================================
//             DEFERRED CREDENTIAL ENDPOINT (Final §9)
// ============================================================================

#ifdef VULNERABLE
rule Wallet_Send_Deferred_Req [color=#d1fae5, role="Wallet"]:
  let
    pkE_new = pk(~skE_W)
    dpopPD  = dpopProofDef($CI, pkDPoP, ~jti_d, AT, ~skDPoP)
    inner   = <'def-req', AT, dpopPD, tid, 'crypt-resp', pkE_new>
    outer   = <'def-req-jwe', penc(inner, pkR_CI, ~rEnc)>
  in
    [ W_AwaitingDeferred($Wid, $CI, $AS, ~sid, AT,
                         ~skH, pkH, ~skE_W, pkE_W, ~skDPoP, pkDPoP, tid),
      !CI_ReqEncPk($CI, pkR_CI),
      Fr(~jti_d), Fr(~rEnc) ]
  --[ Wallet_Sent_Deferred_Req($Wid, $CI, ~sid, tid, pkE_new) ]->
    [ W_DeferredSent($Wid, $CI, $AS, ~sid, AT,
                     ~skH, pkH, ~skE_W, pkE_W, ~skDPoP, pkDPoP, tid),
      Out(outer) ]

rule CI_Deferred_Endpoint_Vuln [color=#fef9c3, role="CI"]:
  let
    cred    = credentialSig($CI, pkH, ~ltkCI)
    dpopPD  = dpopProofDef($CI, pkDPoP, jti_d, AT, skDPoP_x)
    inner   = <'def-req', AT, dpopPD, tid, 'crypt-resp', pkE_new>
    outer   = <'def-req-jwe', penc(inner, pk(~skR_CI), rEnc)>
    encCred = penc(<'cred-resp', cred>, pkE_new, ~rRespEnc)
  in
    [ In(outer),
      !CI_ReqEncSk($CI, ~skR_CI),
      !CI_PendingTx_Vuln($CI, tid, AT, $AS, $Wid_at, pkDPoP, pkH),
      !Ltk_CI($CI, ~ltkCI),
      Fr(~rRespEnc) ]
  --[ _restrict( verify(dpopPD, dpopPayloadDef($CI, pkDPoP, jti_d, AT),
                        pkDPoP) = true ),
      OnlyOnceV(<'dpop-jti-def', jti_d>),
      OnlyOnceV(<'tid-redeemed', tid>),
      CI_Issued_Credential_Vuln($CI, $AS, $Wid_at, pkH, cred,
                                AT, tid, pkE_new),
      CredIssued_For_PkH($CI, pkH, AT, tid),
      CredEncryptedTo($CI, cred, pkE_new),
      BoundCredential(cred, pkH) ]->
    [ Out(encCred) ]

rule Wallet_Receive_Credential_Vuln [color=#d1fae5, role="Wallet"]:
  let
    sig     = credentialSig($CI, pkH, ~ltkCI)
    encCred = penc(<'cred-resp', sig>, pk(~skE_W), rRespEnc)
  in
    [ W_DeferredSent($Wid, $CI, $AS, ~sid, AT,
                     ~skH, pkH, ~skE_W, pkE_W, ~skDPoP, pkDPoP, tid),
      In(encCred),
      !Ltk_CI($CI, ~ltkCI) ]
  --[ Wallet_Accepted_Credential($Wid, $CI, ~sid, pkH, sig),
      Finish($Wid, $CI, ~sid) ]->
    [ !Wallet_Holds_Credential($Wid, pkH, ~skH, sig) ]
#endif

