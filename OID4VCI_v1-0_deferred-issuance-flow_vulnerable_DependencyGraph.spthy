lemma exec_full_honest_deferred_flow:
  exists-trace
  "∃ Wid CI sid pkH sig #f.
    (((((((Finish( Wid, CI, sid ) @ #f) ∧
          (Wallet_Accepted_Credential( Wid, CI, sid, pkH, sig ) @ #f)) ∧
         (¬(∃ #r. Reveal_CI( CI ) @ #r))) ∧
        (¬(∃ p #r. Reveal_HolderKey( Wid, p ) @ #r))) ∧
       (¬(∃ p #r. Reveal_WalletEncKey( Wid, p ) @ #r))) ∧
      (¬(∃ at #r. Reveal_StoredAT( Wid, CI, at ) @ #r))) ∧
     (¬(∃ p #r. Reveal_DPoPKey( Wid, p ) @ #r))) ∧
    (¬(∃ t #r. Reveal_TxId( Wid, CI, t ) @ #r))"
/*
guarded formula characterizing all satisfying traces:
"∃ Wid CI sid pkH sig #f.
  (Finish( Wid, CI, sid ) @ #f) ∧
  (Wallet_Accepted_Credential( Wid, CI, sid, pkH, sig ) @ #f)
 ∧
  (∀ #r. (Reveal_CI( CI ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_HolderKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_WalletEncKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ at #r. (Reveal_StoredAT( Wid, CI, at ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_DPoPKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ t #r. (Reveal_TxId( Wid, CI, t ) @ #r) ⇒ ⊥)"
*/
simplify
solve( W_DeferredSent( $Wid, $CI, $AS, ~sid, AT, ~skH, pkH, ~skE_W,
                       pkE_W, ~skDPoP, pkDPoP, tid
       ) ▶₀ #f )
  case Wallet_Send_Deferred_Req___VARIANT_1
  solve( !Ltk_CI( $CI, ~ltkCI ) ▶₂ #f )
    case Register_CI
    solve( !KU( penc(<'cred-resp', 
                      sign(<'credential', $CI, 'PII-dataset', pk(~skH)>, ~ltkCI)>,
                     pk(~skE_W), rRespEnc)
           ) @ #vk )
      case CI_Deferred_Endpoint_Vuln___VARIANT_2
      solve( !KU( penc(<'202-deferred', tid>, pk(~skE_W), rRespEnc.1)
             ) @ #vk.1 )
        case CI_Credential_Endpoint_Defer___VARIANT_4
        solve( !KU( penc(<'def-req', 
                          aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1), 
                          sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP.1), jti_d.1, 
                                aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                               ~skDPoP.1), 
                          ~tid_ci.1, 'crypt-resp', pk(~skE_W)>,
                         pk(~skR_CI), rEnc.2)
               ) @ #vk.4 )
          case Wallet_Send_Deferred_Req___VARIANT_1
          solve( !KU( penc(<'credential-req', 
                            aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                            sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), jti_c.1, 
                                  aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                 ~skDPoP), 
                            pk(~skH), 
                            sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, iat.1>, ~skH), 
                            'crypt-resp', pk(~skE_W)>,
                           pk(~skR_CI), rEnc.2)
                 ) @ #vk.7 )
            case Wallet_Send_Credential_Req___VARIANT_1
            SOLVED // trace found
          qed
        qed
      qed
    qed
  qed
qed

lemma P50_holder_binding_preserved [heuristic={P50_tactic}]:
  all-traces
  "∀ CI pkH AT tid #i.
    (((CredIssued_For_PkH( CI, pkH, AT, tid ) @ #i) ∧
      (¬(∃ #r. Reveal_CI( CI ) @ #r))) ∧
     (¬(∃ #r. Reveal_CI_ReqEncKey( CI ) @ #r))) ⇒
    (((∃ Wid s #g. (WalletGen_HolderKey( Wid, s, pkH ) @ #g) ∧ (#g < #i)) ∨
      (∃ Wid #r. (Reveal_HolderKey( Wid, pkH ) @ #r) ∧ (#r < #i))) ∨
     (∃ #k. (!KU( pkH ) @ #k) ∧ (#k < #i)))"
/*
guarded formula characterizing all counter-examples:
"∃ CI pkH AT tid #i.
  (CredIssued_For_PkH( CI, pkH, AT, tid ) @ #i)
 ∧
  (∀ #r. (Reveal_CI( CI ) @ #r) ⇒ ⊥) ∧
  (∀ #r. (Reveal_CI_ReqEncKey( CI ) @ #r) ⇒ ⊥) ∧
  (∀ Wid s #g. (WalletGen_HolderKey( Wid, s, pkH ) @ #g) ⇒ ¬(#g < #i)) ∧
  (∀ Wid #r. (Reveal_HolderKey( Wid, pkH ) @ #r) ⇒ ¬(#r < #i)) ∧
  (∀ #k. (!KU( pkH ) @ #k) ⇒ ¬(#k < #i))"
*/
simplify
solve( CredIssued_For_PkH( CI, pkH, AT, tid ) @ #i )
  case CI_Deferred_Endpoint_Vuln___VARIANT_2
  solve( !KU( penc(<'def-req', AT, 
                    sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(skDPoP_x), jti_d, AT>,
                         skDPoP_x), 
                    tid, 'crypt-resp', pkE_new>,
                   pk(~skR_CI), rEnc)
         ) @ #vk.2 )
    case Wallet_Send_Deferred_Req___VARIANT_1
    solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
      case CI_Publish_RequestEncKey
      solve( !CI_PendingTx_Vuln( $CI, tid,
                                 aToken(~atSecret, pk(~skDPoP), $CI, $AS), $AS.1, $Wid_at, pk(~skDPoP),
                                 pkH
             ) ▶₂ #i )
        case CI_Credential_Endpoint_Defer___VARIANT_4
        solve( !Ltk_CI( $CI, ~ltkCI ) ▶₃ #i )
          case Register_CI
          solve( !KU( penc(<'202-deferred', ~tid_ci>, pk(~skE_W), rRespEnc.1)
                 ) @ #vk.3 )
            case CI_Credential_Endpoint_Defer___VARIANT_4
            solve( !KU( penc(<'credential-req', 
                              aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                              sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), jti_c.1, 
                                    aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                   ~skDPoP), 
                              pk(skH_x), 
                              sign(<'openid4vci-proof+jwt', 'ES256', pk(skH_x), $CI, iat.1>, skH_x), 
                              'crypt-resp', pk(~skE_W)>,
                             pk(~skR_CI), rEnc.2)
                   ) @ #vk.6 )
              case Wallet_Send_Credential_Req___VARIANT_1
              by contradiction /* from formulas */
            next
              case c_penc
              by contradiction /* from formulas */
            qed
          next
            case c_penc
            solve( !KU( pk(~skE_W) ) @ #vk.8 )
              case Wallet_Send_Credential_Req___VARIANT_1
              by contradiction /* from formulas */
            next
              case Wallet_Send_Deferred_Req___VARIANT_1
              by contradiction /* cyclic */
            next
              case c_pk
              solve( !KU( penc(<'credential-req', 
                                aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                                sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), jti_c.1, 
                                      aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                     ~skDPoP), 
                                pk(skH_x), 
                                sign(<'openid4vci-proof+jwt', 'ES256', pk(skH_x), $CI, iat.1>, skH_x), 
                                'crypt-resp', pkE_W>,
                               pk(~skR_CI), rEnc.2)
                     ) @ #vk.7 )
                case Wallet_Send_Credential_Req___VARIANT_1
                by contradiction /* from formulas */
              next
                case c_penc
                by contradiction /* from formulas */
              qed
            qed
          qed
        qed
      qed
    qed
  next
    case c_penc
    solve( !KU( pk(~skR_CI) ) @ #vk.4 )
      case CI_Publish_RequestEncKey
      solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
        case CI_Publish_RequestEncKey
        solve( !CI_PendingTx_Vuln( $CI, tid, AT, $AS, $Wid_at, pk(skDPoP_x), pkH
               ) ▶₂ #i )
          case CI_Credential_Endpoint_Defer___VARIANT_4
          solve( !Ltk_CI( $CI, ~ltkCI ) ▶₃ #i )
            case Register_CI
            solve( !KU( sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP), 
                              jti_d, aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                             ~skDPoP)
                   ) @ #vk.10 )
              case Wallet_Send_Deferred_Req___VARIANT_1
              by contradiction /* from formulas */
            next
              case c_sign
              solve( !KU( pk(~skDPoP) ) @ #vk.30 )
                case c_pk
                solve( !KU( penc(<'credential-req', 
                                  aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                                  sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), jti_c, 
                                        aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                       ~skDPoP), 
                                  pk(skH_x), 
                                  sign(<'openid4vci-proof+jwt', 'ES256', pk(skH_x), $CI, iat>, skH_x), 
                                  'crypt-resp', pkE_W>,
                                 pk(~skR_CI), rEnc.1)
                       ) @ #vk.21 )
                  case Wallet_Send_Credential_Req___VARIANT_1
                  by contradiction /* from formulas */
                next
                  case c_penc
                  by contradiction /* from formulas */
                qed
              qed
            qed
          qed
        qed
      qed
    next
      case Register_CI
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case Wallet_Send_Credential_Req___VARIANT_1_case_1
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case Wallet_Send_Credential_Req___VARIANT_1_case_2
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case Wallet_Send_Deferred_Req___VARIANT_1
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case c_pk
      solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
        case CI_Publish_RequestEncKey
        by contradiction /* from formulas */
      qed
    qed
  qed
qed

lemma c2_attack_witness [heuristic={c2_witness_tactic}]:
  exists-trace
  "∃ CI AS Wid pkH cred AT tid pkE_Adv pkD sid #w #i #k #r_t #r_at #r_dp.
    ((((((((((((((Wallet_Sent_Cred_Req( Wid, CI, sid, pkH, AT ) @ #w) ∧
                 (CI_Issued_Credential_Vuln( CI, AS, Wid, pkH, cred, AT, tid, pkE_Adv
                  ) @ #i)) ∧
                (K( cred ) @ #k)) ∧
               (Reveal_TxId( Wid, CI, tid ) @ #r_t)) ∧
              (Reveal_StoredAT( Wid, CI, AT ) @ #r_at)) ∧
             (Reveal_DPoPKey( Wid, pkD ) @ #r_dp)) ∧
            (#w < #r_t)) ∧
           (#r_t < #i)) ∧
          (#r_at < #i)) ∧
         (#r_dp < #i)) ∧
        (#i < #k)) ∧
       (¬(∃ #r. Reveal_CI( CI ) @ #r))) ∧
      (¬(∃ #r. Reveal_CI_ReqEncKey( CI ) @ #r))) ∧
     (¬(∃ p #r. Reveal_HolderKey( Wid, p ) @ #r))) ∧
    (¬(∃ p #r. Reveal_WalletEncKey( Wid, p ) @ #r))"
/*
guarded formula characterizing all satisfying traces:
"∃ CI AS Wid pkH cred AT tid pkE_Adv pkD sid #w #i #k #r_t #r_at #r_dp.
  (Wallet_Sent_Cred_Req( Wid, CI, sid, pkH, AT ) @ #w) ∧
  (CI_Issued_Credential_Vuln( CI, AS, Wid, pkH, cred, AT, tid, pkE_Adv
   ) @ #i) ∧
  (K( cred ) @ #k) ∧
  (Reveal_TxId( Wid, CI, tid ) @ #r_t) ∧
  (Reveal_StoredAT( Wid, CI, AT ) @ #r_at) ∧
  (Reveal_DPoPKey( Wid, pkD ) @ #r_dp)
 ∧
  (#w < #r_t) ∧
  (#r_t < #i) ∧
  (#r_at < #i) ∧
  (#r_dp < #i) ∧
  (#i < #k) ∧
  (∀ #r. (Reveal_CI( CI ) @ #r) ⇒ ⊥) ∧
  (∀ #r. (Reveal_CI_ReqEncKey( CI ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_HolderKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_WalletEncKey( Wid, p ) @ #r) ⇒ ⊥)"
*/
simplify
solve( CI_Issued_Credential_Vuln( $CI, AS.1, $Wid, pk(~skH), cred, AT,
                                  tid, pkE_Adv
       ) @ #i )
  case CI_Deferred_Endpoint_Vuln___VARIANT_2
  solve( !PendingTxId( $Wid, $CI, tid ) ▶₀ #r_t )
    case CI_Credential_Endpoint_Defer___VARIANT_4
    solve( !StoredAT( $Wid, $CI, AT ) ▶₀ #r_at )
      case Wallet_Get_AT
      solve( !StoredDPoPKey( $Wid, ~skDPoP.1, pkD ) ▶₀ #r_dp )
        case Wallet_Get_AT
        solve( !CI_PendingTx_Vuln( $CI, ~tid_ci,
                                   aToken(~atSecret, pk(~skDPoP), $CI, $AS), $AS.1, $Wid, pk(skDPoP_x),
                                   pk(~skH)
               ) ▶₂ #i )
          case CI_Credential_Endpoint_Defer___VARIANT_4
          solve( W_HasAT( $Wid, $CI, $AS.1, ~sid,
                          aToken(~atSecret, pk(~skDPoP), $CI, $AS), ~skDPoP.2, pkDPoP
                 ) ▶₀ #w )
            case Wallet_Get_AT
            solve( !CI_ReqEncPk( $CI, pkR_CI ) ▶₁ #w )
              case CI_Publish_RequestEncKey
              solve( !KU( penc(<'def-req', aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                                sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP), jti_d, 
                                      aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                     ~skDPoP), 
                                ~tid_ci, 'crypt-resp', pkE_Adv>,
                               pk(~skR_CI), rEnc)
                     ) @ #vk.3 )
                case c_penc
                solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
                  case CI_Publish_RequestEncKey
                  solve( !Ltk_CI( $CI, ~ltkCI ) ▶₃ #i )
                    case Register_CI
                    solve( !KU( sign(<'credential', $CI, 'PII-dataset', pk(~skH)>, ~ltkCI)
                           ) @ #vk.2 )
                      case CI_Deferred_Endpoint_Vuln___VARIANT_2
                      solve( !KU( penc(<'credential-req', 
                                        aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                                        sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), jti_c, 
                                              aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                             ~skDPoP), 
                                        pk(~skH), 
                                        sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, iat>, ~skH), 
                                        'crypt-resp', pkE_W>,
                                       pk(~skR_CI), rEnc.1)
                             ) @ #vk.8 )
                        case Wallet_Send_Credential_Req___VARIANT_1
                        solve( !KU( pk(~skR_CI) ) @ #vk.10 )
                          case CI_Publish_RequestEncKey
                          solve( !KU( aToken(~atSecret, pk(~skDPoP), $CI, $AS) ) @ #vk.14 )
                            case Reveal_StoredAT_Rule
                            solve( !KU( sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP), 
                                              jti_d, aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                             ~skDPoP)
                                   ) @ #vk.16 )
                              case c_sign
                              solve( !KU( penc(<'def-req', 
                                                aToken(~atSecret.2, pk(~skDPoP.2), $CI, $AS.2), 
                                                sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP.2), 
                                                      jti_d.1, aToken(~atSecret.2, pk(~skDPoP.2), $CI, $AS.2)
                                                     >,
                                                     ~skDPoP.2), 
                                                ~tid_ci.1, 'crypt-resp', pk(k.1)>,
                                               pk(~skR_CI), rEnc.2)
                                     ) @ #vk.23 )
                                case c_penc
                                solve( !KU( penc(<'credential-req', 
                                                  aToken(~atSecret.2, pk(~skDPoP.2), $CI, $AS.2), 
                                                  sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP.2), 
                                                        jti_c.1, 
                                                        aToken(~atSecret.2, pk(~skDPoP.2), $CI, $AS.2)>,
                                                       ~skDPoP.2), 
                                                  pk(~skH), 
                                                  sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, iat.1
                                                       >,
                                                       ~skH), 
                                                  'crypt-resp', pkE_W>,
                                                 pk(~skR_CI), rEnc.3)
                                       ) @ #vk.28 )
                                  case Wallet_Send_Credential_Req___VARIANT_1
                                  solve( !KU( pk(~skDPoP) ) @ #vk.32 )
                                    case c_pk
                                    solve( !KU( pk(k) ) @ #vk.24 )
                                      case CI_Publish_RequestEncKey
                                      solve( !CI_ReqEncSk( $CI.2, ~skR ) ▶₀ #l )
                                        case CI_Publish_RequestEncKey
                                        solve( !KU( ~tid_ci ) @ #vk.26 )
                                          case Reveal_TxId_Rule
                                          solve( !KU( ~skDPoP ) @ #vk.28 )
                                            case Reveal_DPoPKey_Rule
                                            solve( !KU( ~skR ) @ #vk.10 )
                                              case Reveal_CI_ReqEncKey_Rule
                                              solve( !CI_ReqEncSk( $CI.1, ~skR.1 ) ▶₀ #l.1 )
                                                case CI_Publish_RequestEncKey
                                                SOLVED // trace found
                                              qed
                                            qed
                                          qed
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma P10_credential_secrecy_vuln:
  all-traces
  "∀ CI AS Wid pkH cred AT tid pkE_new sid #i #g.
    ((((((CI_Issued_Credential_Vuln( CI, AS, Wid, pkH, cred, AT, tid, pkE_new
          ) @ #i) ∧
         (WalletGen_HolderKey( Wid, sid, pkH ) @ #g)) ∧
        (¬(∃ #r. Reveal_CI( CI ) @ #r))) ∧
       (¬(∃ #r. Reveal_CI_ReqEncKey( CI ) @ #r))) ∧
      (¬(∃ p #r. Reveal_HolderKey( Wid, p ) @ #r))) ∧
     (¬(∃ p #r. Reveal_WalletEncKey( Wid, p ) @ #r))) ⇒
    (¬(∃ #k. K( cred ) @ #k))"
/*
guarded formula characterizing all counter-examples:
"∃ CI AS Wid pkH cred AT tid pkE_new sid #i #g.
  (CI_Issued_Credential_Vuln( CI, AS, Wid, pkH, cred, AT, tid, pkE_new
   ) @ #i) ∧
  (WalletGen_HolderKey( Wid, sid, pkH ) @ #g)
 ∧
  (∀ #r. (Reveal_CI( CI ) @ #r) ⇒ ⊥) ∧
  (∀ #r. (Reveal_CI_ReqEncKey( CI ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_HolderKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_WalletEncKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∃ #k. (K( cred ) @ #k))"
*/
simplify
solve( W_HasAT( $Wid, $CI, $AS, ~sid, AT, ~skDPoP, pkDPoP ) ▶₀ #g )
  case Wallet_Get_AT
  solve( !CI_ReqEncPk( $CI, pkR_CI ) ▶₁ #g )
    case CI_Publish_RequestEncKey
    solve( CI_Issued_Credential_Vuln( CI.1, AS.1, $Wid, pk(~skH), cred, AT,
                                      tid, pkE_new
           ) @ #i )
      case CI_Deferred_Endpoint_Vuln___VARIANT_2
      solve( !CI_ReqEncSk( $CI.1, ~skR_CI.1 ) ▶₁ #i )
        case CI_Publish_RequestEncKey
        solve( !CI_PendingTx_Vuln( $CI.1, tid, AT, $AS.1, $Wid, pk(skDPoP_x),
                                   pk(~skH)
               ) ▶₂ #i )
          case CI_Credential_Endpoint_Defer___VARIANT_4
          solve( !Ltk_CI( $CI.1, ~ltkCI ) ▶₃ #i )
            case Register_CI
            solve( !KU( sign(<'credential', $CI.1, 'PII-dataset', pk(~skH)>, ~ltkCI)
                   ) @ #vk )
              case CI_Deferred_Endpoint_Vuln___VARIANT_2
              solve( !KU( penc(<'def-req', 
                                aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1), 
                                sign(<'dpop+jwt', $CI.1, 'POST', 'deferred', pk(~skDPoP.1), jti_d, 
                                      aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1)>,
                                     ~skDPoP.1), 
                                ~tid_ci, 'crypt-resp', pkE_new>,
                               pk(~skR_CI.1), rEnc.1)
                     ) @ #vk.4 )
                case c_penc
                solve( !KU( aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1) ) @ #vk.17 )
                  case Reveal_StoredAT_Rule
                  solve( !KU( ~tid_ci ) @ #vk.21 )
                    case Reveal_TxId_Rule
                    solve( !KU( sign(<'dpop+jwt', $CI.1, 'POST', 'deferred', pk(~skDPoP.1), 
                                      jti_d, aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1)>,
                                     ~skDPoP.1)
                           ) @ #vk.20 )
                      case c_sign
                      solve( !KU( ~skDPoP.1 ) @ #vk.27 )
                        case Reveal_DPoPKey_Rule
                        solve( !KU( penc(<'credential-req', 
                                          aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1), 
                                          sign(<'dpop+jwt', $CI.1, 'POST', 'credential', pk(~skDPoP.1), 
                                                jti_c.1, aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1)>,
                                               ~skDPoP.1), 
                                          pk(~skH), 
                                          sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI.1, iat.1>,
                                               ~skH), 
                                          'crypt-resp', pkE_W>,
                                         pk(~skR_CI.1), rEnc.2)
                               ) @ #vk.18 )
                          case Wallet_Send_Credential_Req___VARIANT_1
                          solve( !KU( penc(<'def-req', 
                                            aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1), 
                                            sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP.1), 
                                                  jti_d.1, aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                                                 ~skDPoP.1), 
                                            ~tid_ci.1, 'crypt-resp', pk(k.1)>,
                                           pk(~skR_CI), rEnc.2)
                                 ) @ #vk.20 )
                            case c_penc
                            solve( !KU( aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1) ) @ #vk.42 )
                              case Reveal_StoredAT_Rule
                              solve( !KU( ~tid_ci.1 ) @ #vk.46 )
                                case Reveal_TxId_Rule
                                solve( !KU( sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP.1), 
                                                  jti_d.1, aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                                                 ~skDPoP.1)
                                       ) @ #vk.46 )
                                  case c_sign
                                  solve( !KU( ~skDPoP.1 ) @ #vk.53 )
                                    case Reveal_DPoPKey_Rule
                                    solve( !KU( penc(<'credential-req', 
                                                      aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1), 
                                                      sign(<'dpop+jwt', $CI, 'POST', 'credential', 
                                                            pk(~skDPoP.1), jti_c.1, 
                                                            aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                                                           ~skDPoP.1), 
                                                      pk(~skH), 
                                                      sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, 
                                                            iat.1>,
                                                           ~skH), 
                                                      'crypt-resp', pkE_W>,
                                                     pk(~skR_CI), rEnc.3)
                                           ) @ #vk.35 )
                                      case Wallet_Send_Credential_Req___VARIANT_1
                                      solve( !KU( pk(~skDPoP) ) @ #vk.32 )
                                        case c_pk
                                        solve( !KU( pk(k) ) @ #vk.28 )
                                          case CI_Publish_RequestEncKey
                                          solve( !CI_ReqEncSk( $CI.1, ~skR ) ▶₀ #l )
                                            case CI_Publish_RequestEncKey
                                            solve( !KU( ~skR ) @ #vk.9 )
                                              case Reveal_CI_ReqEncKey_Rule
                                              solve( !CI_ReqEncSk( $CI.1, ~skR.1 ) ▶₀ #l.1 )
                                                case CI_Publish_RequestEncKey
                                                solve( !KU( pk(~skR_CI) ) @ #vk.25 )
                                                  case CI_Publish_RequestEncKey
                                                  SOLVED // trace found
                                                qed
                                              qed
                                            qed
                                          qed
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma AUTO_typing [sources]:
  all-traces
  "(⊤) ∧
   (∀ x m #i.
     (AUTO_IN_TERM_1_0_0_1__Wallet_Receive_TxId( m, x ) @ #i) ⇒
     ((∃ #j. (!KU( x ) @ #j) ∧ (#j < #i)) ∨
      (∃ #j.
        (AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( m ) @ #j) ∧ (#j < #i))))"
/*
guarded formula characterizing all counter-examples:
"∃ x m #i.
  (AUTO_IN_TERM_1_0_0_1__Wallet_Receive_TxId( m, x ) @ #i)
 ∧
  (∀ #j. (!KU( x ) @ #j) ⇒ ¬(#j < #i)) ∧
  (∀ #j.
    (AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( m ) @ #j) ⇒ ¬(#j < #i))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i))  ∥
         (∃ #j. (!KU( x ) @ #j) ∧ (¬(last(#j))) ∧ (#j < #i))  ∥
         (∃ #j.
           (AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( penc(<'202-deferred', x>,
                                                             pk(~skE_W), rRespEnc)
            ) @ #j)
          ∧
           (¬(last(#j))) ∧ (#j < #i)) )
    case case_1
    solve( W_AwaitingTxId( $Wid, $CI, $AS, ~sid, AT, ~skH, pkH, ~skE_W,
                           pkE_W, ~skDPoP, pkDPoP
           ) ▶₀ #i )
      case Wallet_Send_Credential_Req___VARIANT_1
      solve( !KU( penc(<'202-deferred', x>, pk(~skE_W), rRespEnc) ) @ #vk )
        case CI_Credential_Endpoint_Defer___VARIANT_4
        by contradiction /* from formulas */
      next
        case Wallet_Send_Deferred_Req___VARIANT_1
        solve( (∃ #j. (!KU( tid ) @ #j) ∧ (¬(last(#j))) ∧ (#j < #vr.11))  ∥
               (∃ #j.
                 (AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( penc(<'202-deferred', tid>,
                                                                   pk(~skE_W.1), rRespEnc.1)
                  ) @ #j)
                ∧
                 (¬(last(#j))) ∧ (#j < #vr.11)) )
          case case_1
          by contradiction /* cyclic */
        next
          case case_2
          solve( AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( penc(<'202-deferred', 
