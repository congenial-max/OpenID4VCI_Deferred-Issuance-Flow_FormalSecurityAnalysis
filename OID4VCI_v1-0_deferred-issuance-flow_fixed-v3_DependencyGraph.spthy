lemma AUTO_typing [sources]:
  all-traces
  "(⊤) ∧
   (∀ x m #i.
     (AUTO_IN_TERM_1_0_0_1__Wallet_Receive_TxId( m, x ) @ #i) ⇒
     ((∃ #j. (!KU( x ) @ #j) ∧ (#j < #i)) ∨
      (∃ #j.
        (AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( m ) @ #j) ∧ (#j < #i))))"
/*
guarded formula characterizing all counter-examples:
"∃ x m #i.
  (AUTO_IN_TERM_1_0_0_1__Wallet_Receive_TxId( m, x ) @ #i)
 ∧
  (∀ #j. (!KU( x ) @ #j) ⇒ ¬(#j < #i)) ∧
  (∀ #j.
    (AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( m ) @ #j) ⇒ ¬(#j < #i))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i))  ∥
         (∃ #j. (!KU( x ) @ #j) ∧ (¬(last(#j))) ∧ (#j < #i))  ∥
         (∃ #j.
           (AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( penc(<'202-deferred', x>,
                                                             pk(~skE_W), rRespEnc)
            ) @ #j)
          ∧
           (¬(last(#j))) ∧ (#j < #i)) )
    case case_1
    solve( W_AwaitingTxId_V3( $Wid, $CI, $AS, ~sid, AT, ~skH, pkH, ~skE_W,
                              pkE_W, ~skB, pkB, ~skDPoP, pkDPoP
           ) ▶₀ #i )
      case Wallet_Send_Credential_Req___VARIANT_1
      solve( !KU( penc(<'202-deferred', x>, pk(~skE_W), rRespEnc) ) @ #vk )
        case CI_Credential_Endpoint_Defer___VARIANT_4
        by contradiction /* from formulas */
      next
        case Wallet_Send_Deferred_Req___VARIANT_1
        solve( (∃ #j. (!KU( tid ) @ #j) ∧ (¬(last(#j))) ∧ (#j < #vr.11))  ∥
               (∃ #j.
                 (AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( penc(<'202-deferred', tid>,
                                                                   pk(~skE_W.1), rRespEnc.1)
                  ) @ #j)
                ∧
