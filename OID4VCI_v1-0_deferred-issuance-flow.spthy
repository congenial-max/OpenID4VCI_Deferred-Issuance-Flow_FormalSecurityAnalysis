                        pkB) = true ),
      OnlyOnceV(<'dpop-jti-def', jti_d>),
      OnlyOnceV(<'tid-redeemed', tid>),
      CI_Issued_Credential_Fixed($CI, $AS, $Wid_at, pkH, cred,
                                 AT, tid, pkE_new, pkB),
      CredIssued_For_PkH($CI, pkH, AT, tid),
      CredEncryptedTo($CI, cred, pkE_new),
      BoundCredential(cred, pkH) ]->
    [ Out(encCred) ]

rule Wallet_Receive_Credential_V3 [color=#d1fae5, role="Wallet"]:
  let
    sig     = credentialSig($CI, pkH, ~ltkCI)
    encCred = penc(<'cred-resp', sig>, pk(~skE_W), rRespEnc)
  in
    [ W_DeferredSent_V3($Wid, $CI, $AS, ~sid, AT,
                        ~skH, pkH, ~skE_W, pkE_W, ~skB, pkB,
                        ~skDPoP, pkDPoP, tid),
      In(encCred),
      !Ltk_CI($CI, ~ltkCI) ]
  --[ Wallet_Accepted_Credential($Wid, $CI, ~sid, pkH, sig),
      Finish($Wid, $CI, ~sid) ]->
    [ !Wallet_Holds_Credential($Wid, pkH, ~skH, sig) ]
#endif


// ============================================================================
//                              LEMMAS
// ============================================================================

// Secrecy helpers (close enumeration loops in headline lemmas)

lemma skR_CI_secrecy [reuse, use_induction]:
  "All CI skR #r #i.
       CIReqEncSk(CI, skR) @ r & KU(skR) @ i
     ==> (Ex #l. Reveal_CI_ReqEncKey(CI) @ l & l < i)"

lemma ltkCI_secrecy [reuse, use_induction]:
  "All CI k #r #i.
       CIKey(CI, k) @ r & KU(k) @ i
     ==> (Ex #l. Reveal_CI(CI) @ l & l < i)"

lemma skH_secrecy [reuse, use_induction]:
  "All Wid skH pkH #r #i.
       HolderKeyFresh(Wid, skH, pkH) @ r & KU(skH) @ i
     ==> (Ex #l. Reveal_HolderKey(Wid, pkH) @ l & l < i)"

lemma skE_W_secrecy [reuse, use_induction]:
  "All Wid skE pkE #r #i.
       EncKeyFresh(Wid, skE, pkE) @ r & KU(skE) @ i
     ==> (Ex #l. Reveal_WalletEncKey(Wid, pkE) @ l & l < i)"

// Uniqueness helpers

lemma helper_pkH_unique [reuse, use_induction]:
  "All Wid1 Wid2 s1 s2 pkH #i #j.
       WalletGen_HolderKey(Wid1, s1, pkH) @ i
     & WalletGen_HolderKey(Wid2, s2, pkH) @ j
     ==> #i = #j"

lemma helper_pkE_unique [reuse, use_induction]:
  "All Wid1 Wid2 s1 s2 pkE #i #j.
       WalletGen_EncKey(Wid1, s1, pkE) @ i
     & WalletGen_EncKey(Wid2, s2, pkE) @ j
     ==> #i = #j"

#ifdef FIXED
lemma helper_skB_unique [reuse, use_induction]:
  "All Wid1 Wid2 s1 s2 pkB #i #j.
       WalletGen_BindKey(Wid1, s1, pkB) @ i
     & WalletGen_BindKey(Wid2, s2, pkB) @ j
     ==> #i = #j"
#endif

#ifdef FIXED_V2
lemma helper_skB_unique [reuse, use_induction]:
  "All Wid1 Wid2 s1 s2 pkB #i #j.
       WalletGen_BindKey(Wid1, s1, pkB) @ i
     & WalletGen_BindKey(Wid2, s2, pkB) @ j
     ==> #i = #j"
#endif

#ifdef FIXED_V3
lemma helper_skB_unique [reuse, use_induction]:
  "All Wid1 Wid2 s1 s2 pkB #i #j.
       WalletGen_BindKey(Wid1, s1, pkB) @ i
     & WalletGen_BindKey(Wid2, s2, pkB) @ j
     ==> #i = #j"
#endif


// Executability

lemma exec_full_honest_deferred_flow:
  exists-trace
  "Ex Wid CI sid pkH sig #f.
        Finish(Wid, CI, sid) @ f
      & Wallet_Accepted_Credential(Wid, CI, sid, pkH, sig) @ f
      & HonestCI(CI)
      & NoHolderKeyLeak(Wid)
      & NoEncKeyLeak(Wid)
      & NoStoredATLeak(Wid, CI)
      & NoDPoPKeyLeak(Wid)
      & NoTxIdLeak(Wid, CI)"


// P-50 holder binding (holds in all configurations)

tactic: P50_tactic
    presort: C
    prio:
      regex "WalletGen_HolderKey\("
      regex "Reveal_HolderKey\("
      regex "!KU\( pk\("
      regex "CredIssued_For_PkH\("
    deprio:
      regex "!KU\( ~skR_CI"
      regex "!KU\( ~ltkCI"
      regex "!KU\( ~skE"
      regex "!KU\( ~skH"
      regex "!KU\( ~skDPoP"
      regex "!KU\( ~atSecret"
      regex "!KU\( ~"

lemma P50_holder_binding_preserved [heuristic={P50_tactic}]:
  "All CI pkH AT tid #i.
       CredIssued_For_PkH(CI, pkH, AT, tid) @ i
     & HonestCI(CI)
     & HonestCIReqEnc(CI)
     ==> ( (Ex Wid s #g.
              WalletGen_HolderKey(Wid, s, pkH) @ g & g < i)
         | (Ex Wid #r. Reveal_HolderKey(Wid, pkH) @ r & r < i)
         | (Ex #k. KU(pkH) @ k & k < i) )"


// ===========================================================================
//   VULNERABLE: C2 attack
// ===========================================================================

tactic: c2_witness_tactic
    presort: C
    prio:
      regex "CI_Issued_Credential_Vuln\("
      regex "Wallet_Sent_Cred_Req\("
      regex "Reveal_TxId\("
      regex "Reveal_StoredAT\("
      regex "Reveal_DPoPKey\("
      regex "!CI_PendingTx_Vuln\("
      regex "!Valid_AT\("
      regex "!StoredDPoPKey\("
      regex "!StoredAT\("
      regex "!PendingTxId\("
    deprio:
      regex "!KU\( ~skE"
      regex "!KU\( ~skH"
      regex "!KU\( ~ltkCI"
      regex "!KU\( ~"

#ifdef VULNERABLE

lemma c2_attack_witness [heuristic={c2_witness_tactic}]:
  exists-trace
  "Ex CI AS Wid pkH cred AT tid pkE_Adv pkD sid
      #w #i #k #r_t #r_at #r_dp.
        Wallet_Sent_Cred_Req(Wid, CI, sid, pkH, AT) @ w
      & CI_Issued_Credential_Vuln(CI, AS, Wid, pkH, cred,
                                  AT, tid, pkE_Adv) @ i
      & K(cred) @ k
      & Reveal_TxId(Wid, CI, tid) @ r_t
      & Reveal_StoredAT(Wid, CI, AT) @ r_at
      & Reveal_DPoPKey(Wid, pkD) @ r_dp
      & w < r_t & r_t < i & r_at < i & r_dp < i & i < k
      & HonestCI(CI) & HonestCIReqEnc(CI)
      & NoHolderKeyLeak(Wid) & NoEncKeyLeak(Wid)"

lemma P10_credential_secrecy_vuln:
  "All CI AS Wid pkH cred AT tid pkE_new sid #i #g.
       CI_Issued_Credential_Vuln(CI, AS, Wid, pkH, cred,
                                 AT, tid, pkE_new) @ i
     & WalletGen_HolderKey(Wid, sid, pkH) @ g
     & HonestCI(CI) & HonestCIReqEnc(CI)
     & NoHolderKeyLeak(Wid) & NoEncKeyLeak(Wid)
     ==> not (Ex #k. K(cred) @ k)"

#endif


// ===========================================================================
//   FIXED v1: residual attack C2' + scoped P-10
// ===========================================================================

tactic: c2prime_witness_tactic
    presort: C
    prio:
      regex "CI_Issued_Credential_Fixed\("
      regex "Wallet_Sent_Cred_Req\("
      regex "Reveal_TxId\("
      regex "Reveal_StoredAT\("
      regex "Reveal_DPoPKey\("
      regex "Reveal_HolderKey\("
      regex "!CI_PendingTx_Fixed\("
      regex "!Valid_AT\("
      regex "!StoredDPoPKey\("
      regex "!StoredAT\("
      regex "!StoredHolderKey\("
      regex "!PendingTxId\("
    deprio:
      regex "!KU\( ~skE"
      regex "!KU\( ~ltkCI"
      regex "!KU\( ~skR_CI"
      regex "!KU\( ~"

#ifdef FIXED

lemma c2prime_attack_witness_fixed [heuristic={c2prime_witness_tactic}]:
  exists-trace
  "Ex CI AS WidA WidB pkH_A pkH_B cred AT tid pkE_Adv pkB_Adv pkD
      sidA sidB
      #wA #wB #i #k #r_at #r_dp #r_h.
        Wallet_Sent_Cred_Req(WidA, CI, sidA, pkH_A, AT) @ wA
      & WalletGen_HolderKey(WidB, sidB, pkH_B) @ wB
      & CI_Issued_Credential_Fixed(CI, AS, WidA, pkH_B, cred,
                                   AT, tid, pkE_Adv, pkB_Adv) @ i
      & K(cred) @ k
      & Reveal_StoredAT(WidA, CI, AT) @ r_at
      & Reveal_DPoPKey(WidA, pkD) @ r_dp
      & Reveal_HolderKey(WidB, pkH_B) @ r_h
      & not (WidA = WidB)
      & wA < r_at & wB < r_h
      & r_at < i & r_dp < i & r_h < i & i < k
      & HonestCI(CI) & HonestCIReqEnc(CI)
      & NoBindKeyLeak(WidA)
      & NoHolderKeyLeak(WidA) & NoEncKeyLeak(WidA)"

lemma P10_credential_secrecy_fixed:
  "All CI AS Wid pkH cred AT tid pkE_new pkB sid #i #g.
       CI_Issued_Credential_Fixed(CI, AS, Wid, pkH, cred,
                                  AT, tid, pkE_new, pkB) @ i
     & WalletGen_HolderKey(Wid, sid, pkH) @ g    // pkH must be Wid's
     & HonestCI(CI) & HonestCIReqEnc(CI)
     & NoHolderKeyLeak(Wid) & NoEncKeyLeak(Wid) & NoBindKeyLeak(Wid)
     ==> not (Ex #k. K(cred) @ k)"

#endif


// ===========================================================================
//   FIXED_V2 (NEGATIVE RESULT): keyProof-binds-pkB does NOT close C2'
// ===========================================================================

#ifdef FIXED_V2

// Tamarin will FALSIFY this — recorded as the v2 negative result.
lemma c2prime_attack_blocked_v2:
  "All CI AS WidA WidB pkH_A pkH_B cred AT tid pkE_Adv pkB_Adv pkD
       sidA sidB
       #wA #wB #i #r_at #r_dp #r_h.
        Wallet_Sent_Cred_Req(WidA, CI, sidA, pkH_A, AT) @ wA
      & WalletGen_HolderKey(WidB, sidB, pkH_B) @ wB
      & CI_Issued_Credential_Fixed(CI, AS, WidA, pkH_B, cred,
                                   AT, tid, pkE_Adv, pkB_Adv) @ i
      & Reveal_StoredAT(WidA, CI, AT) @ r_at
      & Reveal_DPoPKey(WidA, pkD) @ r_dp
      & Reveal_HolderKey(WidB, pkH_B) @ r_h
      & not (WidA = WidB)
      & HonestCI(CI) & HonestCIReqEnc(CI)
      & NoBindKeyLeak(WidA)
      & NoHolderKeyLeak(WidA) & NoEncKeyLeak(WidA)
      ==> not (Ex #k. K(cred) @ k)"

// Tamarin will FALSIFY this too — also recorded.
lemma P10_credential_secrecy_fixed_v2:
  "All CI AS Wid pkH cred AT tid pkE_new pkB #i.
       CI_Issued_Credential_Fixed(CI, AS, Wid, pkH, cred,
                                  AT, tid, pkE_new, pkB) @ i
     & HonestCI(CI) & HonestCIReqEnc(CI)
     & NoHolderKeyLeak(Wid) & NoEncKeyLeak(Wid) & NoBindKeyLeak(Wid)
     ==> not (Ex #k. K(cred) @ k)"

#endif


// ===========================================================================
//   FIXED_V3: AT-bound pkH closes both C2 and C2'
// ===========================================================================

#ifdef FIXED_V3

// ★ Under v3, the C2' attack pattern is structurally closed.
// Adversary using A's leaked AT is forced to use pkH_A, for which they
// don't have skH_A (NoHolderKeyLeak(WidA)) — keyProof construction fails.
lemma c2prime_attack_blocked_v3:
  "All CI AS WidA WidB pkH_A pkH_B cred AT tid pkE_Adv pkB_Adv pkD
       sidA sidB
       #wA #wB #i #r_at #r_dp #r_h.
        Wallet_Sent_Cred_Req(WidA, CI, sidA, pkH_A, AT) @ wA
      & WalletGen_HolderKey(WidB, sidB, pkH_B) @ wB
      & CI_Issued_Credential_Fixed(CI, AS, WidA, pkH_B, cred,
                                   AT, tid, pkE_Adv, pkB_Adv) @ i
      & Reveal_StoredAT(WidA, CI, AT) @ r_at
      & Reveal_DPoPKey(WidA, pkD) @ r_dp
      & Reveal_HolderKey(WidB, pkH_B) @ r_h
      & not (WidA = WidB)
      & HonestCI(CI) & HonestCIReqEnc(CI)
      & NoBindKeyLeak(WidA)
      & NoHolderKeyLeak(WidA) & NoEncKeyLeak(WidA)
      ==> not (Ex #k. K(cred) @ k)"

// ★ Under v3, P-10 holds WITHOUT the WalletGen_HolderKey honest-pkH
// scoping that v1 required. This is the strongest credential-secrecy
// claim we can make under standard adversary assumptions.
lemma P10_credential_secrecy_fixed_v3:
  "All CI AS Wid pkH cred AT tid pkE_new pkB #i.
       CI_Issued_Credential_Fixed(CI, AS, Wid, pkH, cred,
                                  AT, tid, pkE_new, pkB) @ i
     & HonestCI(CI) & HonestCIReqEnc(CI)
     & NoHolderKeyLeak(Wid) & NoEncKeyLeak(Wid) & NoBindKeyLeak(Wid)
     ==> not (Ex #k. K(cred) @ k)"

#endif


end

