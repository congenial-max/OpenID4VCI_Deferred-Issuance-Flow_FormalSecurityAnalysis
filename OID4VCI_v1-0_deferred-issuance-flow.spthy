// Wallet receives 202 deferred response.
#ifdef VULNERABLE
rule Wallet_Receive_TxId [color=#d1fae5, role="Wallet"]:
  let encResp = penc(<'202-deferred', tid>, pk(~skE_W), rRespEnc) in
    [ W_AwaitingTxId($Wid, $CI, $AS, ~sid, AT,
                     ~skH, pkH, ~skE_W, pkE_W, ~skDPoP, pkDPoP),
      In(encResp) ]
  --[ Wallet_Got_TxId($Wid, $CI, ~sid, tid) ]->
    [ W_AwaitingDeferred($Wid, $CI, $AS, ~sid, AT,
                         ~skH, pkH, ~skE_W, pkE_W, ~skDPoP, pkDPoP, tid) ]
#endif

