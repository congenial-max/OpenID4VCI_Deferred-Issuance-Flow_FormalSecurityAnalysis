                  case c_penc
                  solve( !KU( aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1) ) @ #vk.18 )
                    case Reveal_StoredAT_Rule
                    solve( !KU( sign(<'dpop+jwt', $CI.1, 'POST', 'credential', 
                                      pk(~skDPoP.1), jti_c.1, aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1)
                                     >,
