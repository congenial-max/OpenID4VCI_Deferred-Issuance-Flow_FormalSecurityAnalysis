                                                            case CI_Credential_Endpoint_Defer___VARIANT_4
                                                            solve( !KU( pk(k.1) ) @ #vk.66 )
                                                              case CI_Publish_RequestEncKey
                                                              solve( !CI_ReqEncSk( $CI.3, ~skR.1 ) ▶₀ #l.4 )
                                                                case CI_Publish_RequestEncKey
                                                                solve( !KU( ~skDPoP ) @ #vk.69 )
                                                                  case Reveal_DPoPKey_Rule
                                                                  solve( !KU( ~skE ) @ #vk.19 )
                                                                    case Reveal_WalletEncKey_Rule
                                                                    solve( !StoredWalletEncKey( $Wid_at,
                                                                                                ~skE.1,
                                                                                                pk(~skE)
                                                                           ) ▶₀ #l.5 )
