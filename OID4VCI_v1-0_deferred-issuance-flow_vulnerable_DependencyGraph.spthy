theory OID4VCI_C2

begin

// Function signature and definition of the equational theory E

functions: aToken/4[private,constructor],
           aTokenV3/5[private,constructor], fst/1, h/1, pair/2, pdec/2, penc/3,
           pk/1, sign/2, snd/1, true/0, verify/3
equations:
    fst(<x.1, x.2>) = x.1,
    pdec(penc(m, pk(k), r), k) = m,
    snd(<x.1, x.2>) = x.2,
    verify(sign(x.1, x.2), x.1, pk(x.2)) = true

tactic: P50_tactic
presort: C
prio: {id}
  regex"WalletGen_HolderKey\("
  regex"Reveal_HolderKey\("
  regex"!KU\(pk\("
  regex"CredIssued_For_PkH\("
deprio: {id}
  regex"!KU\(~skR_CI"
  regex"!KU\(~ltkCI"
  regex"!KU\(~skE"
  regex"!KU\(~skH"
  regex"!KU\(~skDPoP"
  regex"!KU\(~atSecret"
  regex"!KU\(~"
tactic: c2_witness_tactic
presort: C
prio: {id}
  regex"CI_Issued_Credential_Vuln\("
  regex"Wallet_Sent_Cred_Req\("
  regex"Reveal_TxId\("
  regex"Reveal_StoredAT\("
  regex"Reveal_DPoPKey\("
  regex"!CI_PendingTx_Vuln\("
  regex"!Valid_AT\("
  regex"!StoredDPoPKey\("
  regex"!StoredAT\("
  regex"!PendingTxId\("
deprio: {id}
  regex"!KU\(~skE"
  regex"!KU\(~skH"
  regex"!KU\(~ltkCI"
  regex"!KU\(~"
tactic: c2prime_witness_tactic
presort: C
prio: {id}
  regex"CI_Issued_Credential_Fixed\("
  regex"Wallet_Sent_Cred_Req\("
  regex"Reveal_TxId\("
  regex"Reveal_StoredAT\("
  regex"Reveal_DPoPKey\("
  regex"Reveal_HolderKey\("
  regex"!CI_PendingTx_Fixed\("
  regex"!Valid_AT\("
  regex"!StoredDPoPKey\("
  regex"!StoredAT\("
  regex"!StoredHolderKey\("
  regex"!PendingTxId\("
deprio: {id}
  regex"!KU\(~skE"
  regex"!KU\(~ltkCI"
  regex"!KU\(~skR_CI"
  regex"!KU\(~"

macros: dpopPayloadCred( CI, pkDPoP, jti, AT ) =  <'dpop+jwt', CI, 
                                                   'POST', 'credential', pkDPoP, jti, AT>,
        dpopPayloadDef( CI, pkDPoP, jti, AT ) =  <'dpop+jwt', CI, 'POST', 
                                                  'deferred', pkDPoP, jti, AT>,
        dpopProofCred( CI, pkDPoP, jti, AT, skDPoP ) =  sign(dpopPayloadCred(CI,
                                                                             pkDPoP, jti, AT),
                                                             skDPoP),
        dpopProofDef( CI, pkDPoP, jti, AT, skDPoP ) =  sign(dpopPayloadDef(CI,
                                                                           pkDPoP, jti, AT),
                                                            skDPoP),
        keyProofPayload( CI, pkH, iat ) =  <'openid4vci-proof+jwt', 'ES256', 
                                            pkH, CI, iat>,
        keyProofJWT( CI, pkH, iat, skH ) =  sign(keyProofPayload(CI, pkH, iat),
                                                 skH),
        keyProofPayloadV2( CI, pkH, pkB, iat ) =  <'openid4vci-proof+jwt-v2', 
                                                   'ES256', pkH, h(pkB), CI, iat>,
        keyProofJWTV2( CI, pkH, pkB, iat, skH ) =  sign(keyProofPayloadV2(CI,
                                                                          pkH, pkB, iat),
                                                        skH),
        credPayload( CI, pkH ) =  <'credential', CI, 'PII-dataset', pkH>,
        credentialSig( CI, pkH, ltkCI ) =  sign(credPayload(CI, pkH), ltkCI),
        txIdBindPayload( CI, tid, pkE_new ) =  <'oid4vci-tid-bind', CI, tid, 
                                                h(pkE_new)>,
        txIdBindSig( CI, tid, pkE_new, skB ) =  sign(txIdBindPayload(CI, tid,
                                                                     pkE_new),
                                                     skB)

predicate: HonestCI( CI )<=>¬(∃ #r. Reveal_CI( CI ) @ #r)

predicate: HonestCIReqEnc( CI )<=>¬(∃ #r. Reveal_CI_ReqEncKey( CI ) @ #r)

predicate: NoHolderKeyLeak( Wid )<=>¬(∃ p #r. Reveal_HolderKey( Wid, p ) @ #r)

predicate: NoEncKeyLeak( Wid )<=>¬(∃ p #r. Reveal_WalletEncKey( Wid, p ) @ #r)

predicate: NoBindKeyLeak( Wid )<=>¬(∃ p #r. Reveal_WalletBindKey( Wid, p ) @ #r)

predicate: NoStoredATLeak( Wid, CI )<=>¬(∃ at #r. Reveal_StoredAT( Wid, CI, at ) @ #r)

predicate: NoDPoPKeyLeak( Wid )<=>¬(∃ p #r. Reveal_DPoPKey( Wid, p ) @ #r)

predicate: NoTxIdLeak( Wid, CI )<=>¬(∃ t #r. Reveal_TxId( Wid, CI, t ) @ #r)

restriction Eq:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

  /*
  expanded formula:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  */

restriction OnlyOnceV:
  "∀ x #i #j. ((OnlyOnceV( x ) @ #i) ∧ (OnlyOnceV( x ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ x #i #j. ((OnlyOnceV( x ) @ #i) ∧ (OnlyOnceV( x ) @ #j)) ⇒ (#i = #j)"
  */

restriction UniqueCIKey:
  "∀ CI k1 k2 #i #j.
    ((CIKey( CI, k1 ) @ #i) ∧ (CIKey( CI, k2 ) @ #j)) ⇒ (k1 = k2)"
  // safety formula

  /*
  expanded formula:
  "∀ CI k1 k2 #i #j.
    ((CIKey( CI, k1 ) @ #i) ∧ (CIKey( CI, k2 ) @ #j)) ⇒ (k1 = k2)"
  */

restriction UniqueCIReqEncKey:
  "∀ CI k1 k2 #i #j.
    ((CIReqEncSk( CI, k1 ) @ #i) ∧ (CIReqEncSk( CI, k2 ) @ #j)) ⇒ (k1 = k2)"
  // safety formula

  /*
  expanded formula:
  "∀ CI k1 k2 #i #j.
    ((CIReqEncSk( CI, k1 ) @ #i) ∧ (CIReqEncSk( CI, k2 ) @ #j)) ⇒ (k1 = k2)"
  */

rule (modulo E) Register_CI[color=#fef3c7, role='Setup']:
   [ Fr( ~ltkCI ) ]
  --[
  Register_CI( $CI ), CIKey( $CI, ~ltkCI ),
  OnlyOnceV( <'register-ci', $CI> )
  ]->
   [ !Ltk_CI( $CI, ~ltkCI ), Out( pk(~ltkCI) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) CI_Publish_RequestEncKey[color=#fef3c7, role='Setup']:
   [ Fr( ~skR_CI ), !Ltk_CI( $CI, ~ltkCI ) ]
  --[
  CIRequestEncKey( $CI, pk(~skR_CI) ), CIReqEncSk( $CI, ~skR_CI ),
  OnlyOnceV( <'ci-req-enc', $CI> )
  ]->
   [
   !CI_ReqEncSk( $CI, ~skR_CI ), !CI_ReqEncPk( $CI, pk(~skR_CI) ),
   Out( pk(~skR_CI) )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Wallet_Get_AT[color=#fef9c3, role='Wallet']:
   [ Fr( ~sid ), Fr( ~skDPoP ), Fr( ~atSecret ) ]
  --[
  Wallet_Got_AT( $Wid, $CI, ~sid, aToken(~atSecret, pk(~skDPoP), $CI, $AS)
  ),
  ATIssued( $AS, $CI, $Wid, aToken(~atSecret, pk(~skDPoP), $CI, $AS),
            pk(~skDPoP)
  )
  ]->
   [
   W_HasAT( $Wid, $CI, $AS, ~sid, aToken(~atSecret, pk(~skDPoP), $CI, $AS),
            ~skDPoP, pk(~skDPoP)
   ),
   !Valid_AT( $CI, aToken(~atSecret, pk(~skDPoP), $CI, $AS), $AS, $Wid,
              pk(~skDPoP)
   ),
   !StoredDPoPKey( $Wid, ~skDPoP, pk(~skDPoP) ),
   !StoredAT( $Wid, $CI, aToken(~atSecret, pk(~skDPoP), $CI, $AS) )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_CI_Ltk[color=#fecaca, role='Adv']:
   [ !Ltk_CI( $CI, ~ltkCI ) ] --[ Reveal_CI( $CI ) ]-> [ Out( ~ltkCI ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_CI_ReqEncKey_Rule[color=#fecaca, role='Adv']:
   [ !CI_ReqEncSk( $CI, ~skR ) ]
  --[ Reveal_CI_ReqEncKey( $CI ) ]->
   [ Out( ~skR ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_HolderKey_Rule[color=#fecaca, role='Adv']:
   [ !StoredHolderKey( $Wid, ~skH, pkH ) ]
  --[ Reveal_HolderKey( $Wid, pkH ) ]->
   [ Out( ~skH ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_WalletEncKey_Rule[color=#fecaca, role='Adv']:
   [ !StoredWalletEncKey( $Wid, ~skE, pkE ) ]
  --[ Reveal_WalletEncKey( $Wid, pkE ) ]->
   [ Out( ~skE ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_DPoPKey_Rule[color=#fecaca, role='Adv']:
   [ !StoredDPoPKey( $Wid, ~skDPoP, pkDPoP ) ]
  --[ Reveal_DPoPKey( $Wid, pkDPoP ) ]->
   [ Out( ~skDPoP ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_StoredAT_Rule[color=#fecaca, role='Adv']:
   [ !StoredAT( $Wid, $CI, AT ) ]
  --[ Reveal_StoredAT( $Wid, $CI, AT ) ]->
   [ Out( AT ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_TxId_Rule[color=#fecaca, role='Adv']:
   [ !PendingTxId( $Wid, $CI, tid ) ]
  --[ Reveal_TxId( $Wid, $CI, tid ) ]->
   [ Out( tid ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Wallet_Send_Credential_Req___VARIANT_1[color=#d1fae5,
                                                       role='Wallet']:
   [
   W_HasAT( $Wid, $CI, $AS, ~sid, AT, ~skDPoP, pkDPoP ),
   !CI_ReqEncPk( $CI, pkR_CI ), Fr( ~skH ), Fr( ~iat ), Fr( ~jti_c ),
   Fr( ~skE_W ), Fr( ~rEnc )
   ]
  --[
  Wallet_Sent_Cred_Req( $Wid, $CI, ~sid, pk(~skH), AT ),
  WalletGen_HolderKey( $Wid, ~sid, pk(~skH) ),
  WalletGen_EncKey( $Wid, ~sid, pk(~skE_W) ),
  HolderKeyFresh( $Wid, ~skH, pk(~skH) ),
  EncKeyFresh( $Wid, ~skE_W, pk(~skE_W) )
  ]->
   [
   W_AwaitingTxId( $Wid, $CI, $AS, ~sid, AT, ~skH, pk(~skH), ~skE_W,
                   pk(~skE_W), ~skDPoP, pkDPoP
   ),
   !StoredHolderKey( $Wid, ~skH, pk(~skH) ),
   !StoredWalletEncKey( $Wid, ~skE_W, pk(~skE_W) ),
   Out( <'credential-req-jwe', 
         penc(<'credential-req', AT, 
               sign(<'dpop+jwt', $CI, 'POST', 'credential', pkDPoP, ~jti_c, AT>,
                    ~skDPoP), 
               pk(~skH), 
               sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, ~iat>, ~skH), 
               'crypt-resp', pk(~skE_W)>,
              pkR_CI, ~rEnc)
        >
   )
   ]

  /* has exactly the trivial AC variant */

restriction Restr_CI_Credential_Endpoint_Defer_1:
  "∀ x #NOW.
    (Restr_CI_Credential_Endpoint_Defer_1( x ) @ #NOW) ⇒ (x = true)"
  // safety formula

  /*
  expanded formula:
  "∀ x #NOW.
    (Restr_CI_Credential_Endpoint_Defer_1( x ) @ #NOW) ⇒ (x = true)"
  */

restriction Restr_CI_Credential_Endpoint_Defer_2:
  "∀ x #NOW.
    (Restr_CI_Credential_Endpoint_Defer_2( x ) @ #NOW) ⇒ (x = true)"
  // safety formula

  /*
  expanded formula:
  "∀ x #NOW.
    (Restr_CI_Credential_Endpoint_Defer_2( x ) @ #NOW) ⇒ (x = true)"
  */

rule (modulo E) CI_Credential_Endpoint_Defer[color=#fef9c3, role='CI']:
   [
   In( <'credential-req-jwe', 
        penc(<'credential-req', AT, 
              dpopProofCred($CI, pkDPoP, jti_c, AT, skDPoP_x), pkH, 
              keyProofJWT($CI, pkH, iat, skH_x), 'crypt-resp', pkE_W>,
             pk(~skR_CI), rEnc)
       >
   ),
   !CI_ReqEncSk( $CI, ~skR_CI ), !Valid_AT( $CI, AT, $AS, $Wid_at, pkDPoP ),
   !Ltk_CI( $CI, ~ltkCI ), Fr( ~tid_ci ), Fr( ~rRespEnc )
   ]
  --[
  OnlyOnceV( <'dpop-jti-cred', jti_c> ),
  OnlyOnceV( <'tid-issued', ~tid_ci> ),
  CI_Issued_TxId( $CI, $AS, $Wid_at, ~tid_ci, AT, pkH, pkE_W, pkDPoP ),
  Restr_CI_Credential_Endpoint_Defer_1( verify(keyProofJWT($CI, pkH, iat,
                                                           skH_x),
                                               keyProofPayload($CI, pkH, iat), pkH)
  ),
  Restr_CI_Credential_Endpoint_Defer_2( verify(dpopProofCred($CI, pkDPoP,
                                                             jti_c, AT, skDPoP_x),
                                               dpopPayloadCred($CI, pkDPoP, jti_c, AT), pkDPoP)
  )
  ]->
   [
   !CI_PendingTx_Vuln( $CI, ~tid_ci, AT, $AS, $Wid_at, pkDPoP, pkH ),
   !PendingTxId( $Wid_at, $CI, ~tid_ci ),
   Out( penc(<'202-deferred', ~tid_ci>, pkE_W, ~rRespEnc) )
   ]
 variants
  rule (modulo AC) CI_Credential_Endpoint_Defer___VARIANT_1[color=#fef9c3,
                                                            role='CI']:
     [
     In( <'credential-req-jwe', 
          penc(<'credential-req', AT.3, 
                sign(<'dpop+jwt', $CI.2, 'POST', 'credential', pkDPoP.6, jti_c.5, AT.3>,
                     skDPoP_x.8), 
                pkH.7, 
                sign(<'openid4vci-proof+jwt', 'ES256', pkH.7, $CI.2, iat.4>, skH_x.9), 
                'crypt-resp', pkE_W>,
               pk(~skR_CI), rEnc)
         >
     ),
     !CI_ReqEncSk( $CI.2, ~skR_CI ),
     !Valid_AT( $CI.2, AT.3, $AS, $Wid_at, pkDPoP.6 ),
     !Ltk_CI( $CI.2, ~ltkCI ), Fr( ~tid_ci ), Fr( ~rRespEnc )
     ]
    --[
    AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( penc(<'202-deferred', ~tid_ci
                                                     >,
                                                     pkE_W, ~rRespEnc)
    ),
    OnlyOnceV( <'dpop-jti-cred', jti_c.5> ),
    OnlyOnceV( <'tid-issued', ~tid_ci> ),
    CI_Issued_TxId( $CI.2, $AS, $Wid_at, ~tid_ci, AT.3, pkH.7, pkE_W,
                    pkDPoP.6
    ),
    Restr_CI_Credential_Endpoint_Defer_1( verify(sign(<
                                                       'openid4vci-proof+jwt', 'ES256', pkH.7, $CI.2, iat.4>,
                                                      skH_x.9),
                                                 <'openid4vci-proof+jwt', 'ES256', pkH.7, $CI.2, iat.4>,
                                                 pkH.7)
    ),
    Restr_CI_Credential_Endpoint_Defer_2( verify(sign(<'dpop+jwt', $CI.2, 
                                                       'POST', 'credential', pkDPoP.6, jti_c.5, AT.3>,
                                                      skDPoP_x.8),
                                                 <'dpop+jwt', $CI.2, 'POST', 'credential', pkDPoP.6, jti_c.5, 
                                                  AT.3>,
                                                 pkDPoP.6)
    )
    ]->
     [
     !CI_PendingTx_Vuln( $CI.2, ~tid_ci, AT.3, $AS, $Wid_at, pkDPoP.6, pkH.7
     ),
     !PendingTxId( $Wid_at, $CI.2, ~tid_ci ),
     Out( penc(<'202-deferred', ~tid_ci>, pkE_W, ~rRespEnc) )
     ]
  ,
  rule (modulo AC) CI_Credential_Endpoint_Defer___VARIANT_2[color=#fef9c3,
                                                            role='CI']:
     [
     In( <'credential-req-jwe', 
          penc(<'credential-req', AT.3, 
                sign(<'dpop+jwt', $CI.2, 'POST', 'credential', pkDPoP.5, jti_c.4, AT.3>,
                     skDPoP_x.6), 
                pk(skH_x.7), 
                sign(<'openid4vci-proof+jwt', 'ES256', pk(skH_x.7), $CI.2, iat>,
                     skH_x.7), 
                'crypt-resp', pkE_W>,
               pk(~skR_CI), rEnc)
         >
     ),
     !CI_ReqEncSk( $CI.2, ~skR_CI ),
     !Valid_AT( $CI.2, AT.3, $AS, $Wid_at, pkDPoP.5 ),
     !Ltk_CI( $CI.2, ~ltkCI ), Fr( ~tid_ci ), Fr( ~rRespEnc )
     ]
    --[
    AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( penc(<'202-deferred', ~tid_ci
                                                     >,
                                                     pkE_W, ~rRespEnc)
    ),
    OnlyOnceV( <'dpop-jti-cred', jti_c.4> ),
    OnlyOnceV( <'tid-issued', ~tid_ci> ),
    CI_Issued_TxId( $CI.2, $AS, $Wid_at, ~tid_ci, AT.3, pk(skH_x.7), pkE_W,
                    pkDPoP.5
    ),
    Restr_CI_Credential_Endpoint_Defer_1( true ),
    Restr_CI_Credential_Endpoint_Defer_2( verify(sign(<'dpop+jwt', $CI.2, 
                                                       'POST', 'credential', pkDPoP.5, jti_c.4, AT.3>,
                                                      skDPoP_x.6),
                                                 <'dpop+jwt', $CI.2, 'POST', 'credential', pkDPoP.5, jti_c.4, 
                                                  AT.3>,
                                                 pkDPoP.5)
    )
    ]->
     [
     !CI_PendingTx_Vuln( $CI.2, ~tid_ci, AT.3, $AS, $Wid_at, pkDPoP.5,
                         pk(skH_x.7)
     ),
     !PendingTxId( $Wid_at, $CI.2, ~tid_ci ),
     Out( penc(<'202-deferred', ~tid_ci>, pkE_W, ~rRespEnc) )
     ]
  ,
  rule (modulo AC) CI_Credential_Endpoint_Defer___VARIANT_3[color=#fef9c3,
                                                            role='CI']:
     [
     In( <'credential-req-jwe', 
          penc(<'credential-req', AT, 
                sign(<'dpop+jwt', $CI.2, 'POST', 'credential', pk(skDPoP_x.5), jti_c, AT
                     >,
                     skDPoP_x.5), 
                pkH.4, 
                sign(<'openid4vci-proof+jwt', 'ES256', pkH.4, $CI.2, iat.3>, skH_x.6), 
                'crypt-resp', pkE_W>,
               pk(~skR_CI), rEnc)
         >
     ),
     !CI_ReqEncSk( $CI.2, ~skR_CI ),
     !Valid_AT( $CI.2, AT, $AS, $Wid_at, pk(skDPoP_x.5) ),
     !Ltk_CI( $CI.2, ~ltkCI ), Fr( ~tid_ci ), Fr( ~rRespEnc )
     ]
    --[
    AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( penc(<'202-deferred', ~tid_ci
                                                     >,
                                                     pkE_W, ~rRespEnc)
    ),
    OnlyOnceV( <'dpop-jti-cred', jti_c> ),
    OnlyOnceV( <'tid-issued', ~tid_ci> ),
    CI_Issued_TxId( $CI.2, $AS, $Wid_at, ~tid_ci, AT, pkH.4, pkE_W,
                    pk(skDPoP_x.5)
    ),
    Restr_CI_Credential_Endpoint_Defer_1( verify(sign(<
                                                       'openid4vci-proof+jwt', 'ES256', pkH.4, $CI.2, iat.3>,
                                                      skH_x.6),
                                                 <'openid4vci-proof+jwt', 'ES256', pkH.4, $CI.2, iat.3>,
                                                 pkH.4)
    ),
    Restr_CI_Credential_Endpoint_Defer_2( true )
    ]->
     [
     !CI_PendingTx_Vuln( $CI.2, ~tid_ci, AT, $AS, $Wid_at, pk(skDPoP_x.5),
                         pkH.4
     ),
     !PendingTxId( $Wid_at, $CI.2, ~tid_ci ),
     Out( penc(<'202-deferred', ~tid_ci>, pkE_W, ~rRespEnc) )
     ]
  ,
  rule (modulo AC) CI_Credential_Endpoint_Defer___VARIANT_4[color=#fef9c3,
                                                            role='CI']:
     [
     In( <'credential-req-jwe', 
          penc(<'credential-req', AT, 
                sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(skDPoP_x.2), jti_c, AT>,
                     skDPoP_x.2), 
                pk(skH_x.3), 
                sign(<'openid4vci-proof+jwt', 'ES256', pk(skH_x.3), $CI, iat>, skH_x.3), 
                'crypt-resp', pkE_W>,
               pk(~skR_CI), rEnc)
         >
     ),
     !CI_ReqEncSk( $CI, ~skR_CI ),
     !Valid_AT( $CI, AT, $AS, $Wid_at, pk(skDPoP_x.2) ),
     !Ltk_CI( $CI, ~ltkCI ), Fr( ~tid_ci ), Fr( ~rRespEnc )
     ]
    --[
    AUTO_OUT_TERM_1_0_0_1__Wallet_Receive_TxId( penc(<'202-deferred', ~tid_ci
                                                     >,
                                                     pkE_W, ~rRespEnc)
    ),
    OnlyOnceV( <'dpop-jti-cred', jti_c> ),
    OnlyOnceV( <'tid-issued', ~tid_ci> ),
    CI_Issued_TxId( $CI, $AS, $Wid_at, ~tid_ci, AT, pk(skH_x.3), pkE_W,
                    pk(skDPoP_x.2)
    ),
    Restr_CI_Credential_Endpoint_Defer_1( true ),
    Restr_CI_Credential_Endpoint_Defer_2( true )
    ]->
     [
     !CI_PendingTx_Vuln( $CI, ~tid_ci, AT, $AS, $Wid_at, pk(skDPoP_x.2),
                         pk(skH_x.3)
     ),
     !PendingTxId( $Wid_at, $CI, ~tid_ci ),
     Out( penc(<'202-deferred', ~tid_ci>, pkE_W, ~rRespEnc) )
     ]

rule (modulo E) Wallet_Receive_TxId[color=#d1fae5, role='Wallet']:
   [
   W_AwaitingTxId( $Wid, $CI, $AS, ~sid, AT, ~skH, pkH, ~skE_W, pkE_W,
                   ~skDPoP, pkDPoP
   ),
   In( penc(<'202-deferred', tid>, pk(~skE_W), rRespEnc) )
   ]
  --[
  AUTO_IN_TERM_1_0_0_1__Wallet_Receive_TxId( penc(<'202-deferred', tid>,
                                                  pk(~skE_W), rRespEnc),
                                             tid
  ),
  Wallet_Got_TxId( $Wid, $CI, ~sid, tid )
  ]->
   [
   W_AwaitingDeferred( $Wid, $CI, $AS, ~sid, AT, ~skH, pkH, ~skE_W, pkE_W,
                       ~skDPoP, pkDPoP, tid
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Wallet_Send_Deferred_Req___VARIANT_1[color=#d1fae5,
                                                     role='Wallet']:
   [
   W_AwaitingDeferred( $Wid, $CI, $AS, ~sid, AT, ~skH, pkH, ~skE_W, pkE_W,
                       ~skDPoP, pkDPoP, tid
   ),
   !CI_ReqEncPk( $CI, pkR_CI ), Fr( ~jti_d ), Fr( ~rEnc )
   ]
  --[ Wallet_Sent_Deferred_Req( $Wid, $CI, ~sid, tid, pk(~skE_W) ) ]->
   [
   W_DeferredSent( $Wid, $CI, $AS, ~sid, AT, ~skH, pkH, ~skE_W, pkE_W,
                   ~skDPoP, pkDPoP, tid
   ),
   Out( <'def-req-jwe', 
         penc(<'def-req', AT, 
               sign(<'dpop+jwt', $CI, 'POST', 'deferred', pkDPoP, ~jti_d, AT>,
                    ~skDPoP), 
               tid, 'crypt-resp', pk(~skE_W)>,
              pkR_CI, ~rEnc)
        >
   )
   ]

  /* has exactly the trivial AC variant */

restriction Restr_CI_Deferred_Endpoint_Vuln_1:
  "∀ x #NOW. (Restr_CI_Deferred_Endpoint_Vuln_1( x ) @ #NOW) ⇒ (x = true)"
  // safety formula

  /*
  expanded formula:
  "∀ x #NOW. (Restr_CI_Deferred_Endpoint_Vuln_1( x ) @ #NOW) ⇒ (x = true)"
  */

rule (modulo E) CI_Deferred_Endpoint_Vuln[color=#fef9c3, role='CI']:
   [
   In( <'def-req-jwe', 
        penc(<'def-req', AT, dpopProofDef($CI, pkDPoP, jti_d, AT, skDPoP_x), 
              tid, 'crypt-resp', pkE_new>,
             pk(~skR_CI), rEnc)
       >
   ),
   !CI_ReqEncSk( $CI, ~skR_CI ),
   !CI_PendingTx_Vuln( $CI, tid, AT, $AS, $Wid_at, pkDPoP, pkH ),
   !Ltk_CI( $CI, ~ltkCI ), Fr( ~rRespEnc )
   ]
  --[
  OnlyOnceV( <'dpop-jti-def', jti_d> ), OnlyOnceV( <'tid-redeemed', tid> ),
  CI_Issued_Credential_Vuln( $CI, $AS, $Wid_at, pkH,
                             credentialSig($CI, pkH, ~ltkCI), AT, tid, pkE_new
  ),
  CredIssued_For_PkH( $CI, pkH, AT, tid ),
  CredEncryptedTo( $CI, credentialSig($CI, pkH, ~ltkCI), pkE_new ),
  BoundCredential( credentialSig($CI, pkH, ~ltkCI), pkH ),
  Restr_CI_Deferred_Endpoint_Vuln_1( verify(dpopProofDef($CI, pkDPoP,
                                                         jti_d, AT, skDPoP_x),
                                            dpopPayloadDef($CI, pkDPoP, jti_d, AT), pkDPoP)
  )
  ]->
   [
   Out( penc(<'cred-resp', credentialSig($CI, pkH, ~ltkCI)>, pkE_new,
             ~rRespEnc)
   )
   ]
 variants
  rule (modulo AC) CI_Deferred_Endpoint_Vuln___VARIANT_1[color=#fef9c3,
                                                         role='CI']:
     [
     In( <'def-req-jwe', 
          penc(<'def-req', AT.2, 
                sign(<'dpop+jwt', $CI.1, 'POST', 'deferred', pkDPoP.4, jti_d.3, AT.2>,
                     skDPoP_x.5), 
                tid, 'crypt-resp', pkE_new>,
               pk(~skR_CI), rEnc)
         >
     ),
     !CI_ReqEncSk( $CI.1, ~skR_CI ),
     !CI_PendingTx_Vuln( $CI.1, tid, AT.2, $AS, $Wid_at, pkDPoP.4, pkH ),
     !Ltk_CI( $CI.1, ~ltkCI ), Fr( ~rRespEnc )
     ]
    --[
    OnlyOnceV( <'dpop-jti-def', jti_d.3> ),
    OnlyOnceV( <'tid-redeemed', tid> ),
    CI_Issued_Credential_Vuln( $CI.1, $AS, $Wid_at, pkH,
                               sign(<'credential', $CI.1, 'PII-dataset', pkH>, ~ltkCI), AT.2, tid,
                               pkE_new
    ),
    CredIssued_For_PkH( $CI.1, pkH, AT.2, tid ),
    CredEncryptedTo( $CI.1,
                     sign(<'credential', $CI.1, 'PII-dataset', pkH>, ~ltkCI), pkE_new
    ),
    BoundCredential( sign(<'credential', $CI.1, 'PII-dataset', pkH>, ~ltkCI),
                     pkH
    ),
    Restr_CI_Deferred_Endpoint_Vuln_1( verify(sign(<'dpop+jwt', $CI.1, 
                                                    'POST', 'deferred', pkDPoP.4, jti_d.3, AT.2>,
                                                   skDPoP_x.5),
                                              <'dpop+jwt', $CI.1, 'POST', 'deferred', pkDPoP.4, jti_d.3, AT.2
                                              >,
                                              pkDPoP.4)
    )
    ]->
     [
     Out( penc(<'cred-resp', 
                sign(<'credential', $CI.1, 'PII-dataset', pkH>, ~ltkCI)>,
               pkE_new, ~rRespEnc)
     )
     ]
  ,
  rule (modulo AC) CI_Deferred_Endpoint_Vuln___VARIANT_2[color=#fef9c3,
                                                         role='CI']:
     [
     In( <'def-req-jwe', 
          penc(<'def-req', AT, 
                sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(skDPoP_x.1), jti_d, AT>,
                     skDPoP_x.1), 
                tid, 'crypt-resp', pkE_new>,
               pk(~skR_CI), rEnc)
         >
     ),
     !CI_ReqEncSk( $CI, ~skR_CI ),
     !CI_PendingTx_Vuln( $CI, tid, AT, $AS, $Wid_at, pk(skDPoP_x.1), pkH ),
     !Ltk_CI( $CI, ~ltkCI ), Fr( ~rRespEnc )
     ]
    --[
    OnlyOnceV( <'dpop-jti-def', jti_d> ), OnlyOnceV( <'tid-redeemed', tid> ),
    CI_Issued_Credential_Vuln( $CI, $AS, $Wid_at, pkH,
                               sign(<'credential', $CI, 'PII-dataset', pkH>, ~ltkCI), AT, tid, pkE_new
    ),
    CredIssued_For_PkH( $CI, pkH, AT, tid ),
    CredEncryptedTo( $CI,
                     sign(<'credential', $CI, 'PII-dataset', pkH>, ~ltkCI), pkE_new
    ),
    BoundCredential( sign(<'credential', $CI, 'PII-dataset', pkH>, ~ltkCI),
                     pkH
    ),
    Restr_CI_Deferred_Endpoint_Vuln_1( true )
    ]->
     [
     Out( penc(<'cred-resp', 
                sign(<'credential', $CI, 'PII-dataset', pkH>, ~ltkCI)>,
               pkE_new, ~rRespEnc)
     )
     ]

rule (modulo E) Wallet_Receive_Credential_Vuln___VARIANT_1[color=#d1fae5,
                                                           role='Wallet']:
   [
   W_DeferredSent( $Wid, $CI, $AS, ~sid, AT, ~skH, pkH, ~skE_W, pkE_W,
                   ~skDPoP, pkDPoP, tid
   ),
   In( penc(<'cred-resp', 
             sign(<'credential', $CI, 'PII-dataset', pkH>, ~ltkCI)>,
            pk(~skE_W), rRespEnc)
   ),
   !Ltk_CI( $CI, ~ltkCI )
   ]
  --[
  Wallet_Accepted_Credential( $Wid, $CI, ~sid, pkH,
                              sign(<'credential', $CI, 'PII-dataset', pkH>, ~ltkCI)
  ),
  Finish( $Wid, $CI, ~sid )
  ]->
   [
   !Wallet_Holds_Credential( $Wid, pkH, ~skH,
                             sign(<'credential', $CI, 'PII-dataset', pkH>, ~ltkCI)
   )
   ]

  /* has exactly the trivial AC variant */

lemma skR_CI_secrecy [reuse, use_induction]:
  all-traces
  "∀ CI skR #r #i.
    ((CIReqEncSk( CI, skR ) @ #r) ∧ (!KU( skR ) @ #i)) ⇒
    (∃ #l. (Reveal_CI_ReqEncKey( CI ) @ #l) ∧ (#l < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ CI skR #r #i.
  (CIReqEncSk( CI, skR ) @ #r) ∧ (!KU( skR ) @ #i)
 ∧
  ∀ #l. (Reveal_CI_ReqEncKey( CI ) @ #l) ⇒ ¬(#l < #i)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i))  ∥ (last(#r))  ∥
         (∃ #l. (Reveal_CI_ReqEncKey( $CI ) @ #l) ∧ (¬(last(#l))) ∧ (#l < #i)) )
    case case_1
    solve( !Ltk_CI( $CI, ~ltkCI ) ▶₁ #r )
      case Register_CI
      solve( !KU( ~skR_CI ) @ #i )
        case Reveal_CI_ReqEncKey_Rule
        by contradiction /* from formulas */
      qed
    qed
  next
    case case_2
    solve( !Ltk_CI( $CI, ~ltkCI ) ▶₁ #r )
      case Register_CI
      solve( !KU( ~skR_CI ) @ #i )
        case Reveal_CI_ReqEncKey_Rule
        by contradiction /* from formulas */
      qed
    qed
  next
    case case_3
    by contradiction /* from formulas */
  qed
qed

lemma ltkCI_secrecy [reuse, use_induction]:
  all-traces
  "∀ CI k #r #i.
    ((CIKey( CI, k ) @ #r) ∧ (!KU( k ) @ #i)) ⇒
    (∃ #l. (Reveal_CI( CI ) @ #l) ∧ (#l < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ CI k #r #i.
  (CIKey( CI, k ) @ #r) ∧ (!KU( k ) @ #i)
 ∧
  ∀ #l. (Reveal_CI( CI ) @ #l) ⇒ ¬(#l < #i)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i))  ∥ (last(#r))  ∥
         (∃ #l. (Reveal_CI( $CI ) @ #l) ∧ (¬(last(#l))) ∧ (#l < #i)) )
    case case_1
    solve( !KU( ~ltkCI ) @ #i )
      case Reveal_CI_Ltk
      by contradiction /* from formulas */
    qed
  next
    case case_2
    solve( !KU( ~ltkCI ) @ #i )
      case Reveal_CI_Ltk
      by contradiction /* from formulas */
    qed
  next
    case case_3
    by contradiction /* from formulas */
  qed
qed

lemma skH_secrecy [reuse, use_induction]:
  all-traces
  "∀ Wid skH pkH #r #i.
    ((HolderKeyFresh( Wid, skH, pkH ) @ #r) ∧ (!KU( skH ) @ #i)) ⇒
    (∃ #l. (Reveal_HolderKey( Wid, pkH ) @ #l) ∧ (#l < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ Wid skH pkH #r #i.
  (HolderKeyFresh( Wid, skH, pkH ) @ #r) ∧ (!KU( skH ) @ #i)
 ∧
  ∀ #l. (Reveal_HolderKey( Wid, pkH ) @ #l) ⇒ ¬(#l < #i)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i))  ∥ (last(#r))  ∥
         (∃ #l.
           (Reveal_HolderKey( $Wid, pk(~skH) ) @ #l) ∧ (¬(last(#l))) ∧ (#l < #i)) )
    case case_1
    solve( W_HasAT( $Wid, $CI, $AS, ~sid, AT, ~skDPoP, pkDPoP ) ▶₀ #r )
      case Wallet_Get_AT
      solve( !CI_ReqEncPk( $CI, pkR_CI ) ▶₁ #r )
        case CI_Publish_RequestEncKey
        solve( !KU( ~skH ) @ #i )
          case Reveal_HolderKey_Rule
          by contradiction /* from formulas */
        qed
      qed
    qed
  next
    case case_2
    solve( W_HasAT( $Wid, $CI, $AS, ~sid, AT, ~skDPoP, pkDPoP ) ▶₀ #r )
      case Wallet_Get_AT
      solve( !CI_ReqEncPk( $CI, pkR_CI ) ▶₁ #r )
        case CI_Publish_RequestEncKey
        solve( !KU( ~skH ) @ #i )
          case Reveal_HolderKey_Rule
          by contradiction /* from formulas */
        qed
      qed
    qed
  next
    case case_3
    by contradiction /* from formulas */
  qed
qed

