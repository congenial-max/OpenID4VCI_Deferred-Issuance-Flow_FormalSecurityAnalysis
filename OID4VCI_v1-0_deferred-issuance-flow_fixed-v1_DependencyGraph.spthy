                                                                     rRespEnc.4)
                                                           ) @ #vk.75 )
                                                      case CI_Credential_Endpoint_Defer___VARIANT_4
                                                      solve( !StoredWalletEncKey( $Wid_at, ~skE, pk(~skE_W)
                                                             ) ▶₀ #l )
                                                        case Wallet_Send_Credential_Req___VARIANT_1
                                                        solve( !CI_ReqEncSk( $CI.2, ~skR ) ▶₀ #l.3 )
                                                          case CI_Publish_RequestEncKey
