lemma exec_full_honest_deferred_flow:
  exists-trace
  "∃ Wid CI sid pkH sig #f.
    (((((((Finish( Wid, CI, sid ) @ #f) ∧
          (Wallet_Accepted_Credential( Wid, CI, sid, pkH, sig ) @ #f)) ∧
         (¬(∃ #r. Reveal_CI( CI ) @ #r))) ∧
        (¬(∃ p #r. Reveal_HolderKey( Wid, p ) @ #r))) ∧
       (¬(∃ p #r. Reveal_WalletEncKey( Wid, p ) @ #r))) ∧
      (¬(∃ at #r. Reveal_StoredAT( Wid, CI, at ) @ #r))) ∧
     (¬(∃ p #r. Reveal_DPoPKey( Wid, p ) @ #r))) ∧
    (¬(∃ t #r. Reveal_TxId( Wid, CI, t ) @ #r))"
/*
guarded formula characterizing all satisfying traces:
"∃ Wid CI sid pkH sig #f.
  (Finish( Wid, CI, sid ) @ #f) ∧
  (Wallet_Accepted_Credential( Wid, CI, sid, pkH, sig ) @ #f)
 ∧
  (∀ #r. (Reveal_CI( CI ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_HolderKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_WalletEncKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ at #r. (Reveal_StoredAT( Wid, CI, at ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_DPoPKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ t #r. (Reveal_TxId( Wid, CI, t ) @ #r) ⇒ ⊥)"
*/
simplify
solve( W_DeferredSent_FIXED( $Wid, $CI, $AS, ~sid, AT, ~skH, pkH, ~skE_W,
                             pkE_W, ~skB, pkB, ~skDPoP, pkDPoP, tid
       ) ▶₀ #f )
  case Wallet_Send_Deferred_Req___VARIANT_1
  solve( !Ltk_CI( $CI, ~ltkCI ) ▶₂ #f )
    case Register_CI
    solve( !KU( penc(<'cred-resp', 
                      sign(<'credential', $CI, 'PII-dataset', pk(~skH)>, ~ltkCI)>,
                     pk(~skE_W), rRespEnc)
           ) @ #vk )
      case CI_Deferred_Endpoint_Fixed___VARIANT_4
      solve( !KU( penc(<'202-deferred', tid>, pk(~skE_W), rRespEnc.1)
             ) @ #vk.1 )
        case CI_Credential_Endpoint_Defer___VARIANT_4
        solve( !KU( penc(<'def-req-fixed', 
                          aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1), 
                          sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP.1), jti_d.1, 
                                aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                               ~skDPoP.1), 
                          ~tid_ci.1, 'crypt-resp', pk(~skE_W), 'tid-bind-sig', 
                          sign(<'oid4vci-tid-bind', $CI, ~tid_ci.1, h(pk(~skE_W))>, skB_x)>,
                         pk(~skR_CI), rEnc.2)
               ) @ #vk.4 )
          case Wallet_Send_Deferred_Req___VARIANT_1
          solve( !KU( penc(<'credential-req-fixed', 
                            aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                            sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), jti_c.1, 
                                  aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                 ~skDPoP), 
                            pk(~skH), 
                            sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, iat.1>, ~skH), 
                            'crypt-resp', pk(~skE_W), 'tid-bind', pk(~skB)>,
                           pk(~skR_CI), rEnc.2)
                 ) @ #vk.7 )
            case Wallet_Send_Credential_Req___VARIANT_1
            SOLVED // trace found
          qed
        qed
      qed
    qed
  qed
qed

lemma P50_holder_binding_preserved [heuristic={P50_tactic}]:
  all-traces
  "∀ CI pkH AT tid #i.
    (((CredIssued_For_PkH( CI, pkH, AT, tid ) @ #i) ∧
      (¬(∃ #r. Reveal_CI( CI ) @ #r))) ∧
     (¬(∃ #r. Reveal_CI_ReqEncKey( CI ) @ #r))) ⇒
    (((∃ Wid s #g. (WalletGen_HolderKey( Wid, s, pkH ) @ #g) ∧ (#g < #i)) ∨
      (∃ Wid #r. (Reveal_HolderKey( Wid, pkH ) @ #r) ∧ (#r < #i))) ∨
     (∃ #k. (!KU( pkH ) @ #k) ∧ (#k < #i)))"
/*
guarded formula characterizing all counter-examples:
"∃ CI pkH AT tid #i.
  (CredIssued_For_PkH( CI, pkH, AT, tid ) @ #i)
 ∧
  (∀ #r. (Reveal_CI( CI ) @ #r) ⇒ ⊥) ∧
  (∀ #r. (Reveal_CI_ReqEncKey( CI ) @ #r) ⇒ ⊥) ∧
  (∀ Wid s #g. (WalletGen_HolderKey( Wid, s, pkH ) @ #g) ⇒ ¬(#g < #i)) ∧
  (∀ Wid #r. (Reveal_HolderKey( Wid, pkH ) @ #r) ⇒ ¬(#r < #i)) ∧
  (∀ #k. (!KU( pkH ) @ #k) ⇒ ¬(#k < #i))"
*/
simplify
solve( CredIssued_For_PkH( CI, pkH, AT, tid ) @ #i )
  case CI_Deferred_Endpoint_Fixed___VARIANT_4
  solve( !KU( penc(<'def-req-fixed', AT, 
                    sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(skDPoP_x), jti_d, AT>,
                         skDPoP_x), 
                    tid, 'crypt-resp', pkE_new, 'tid-bind-sig', 
                    sign(<'oid4vci-tid-bind', $CI, tid, h(pkE_new)>, skB_x)>,
                   pk(~skR_CI), rEnc)
         ) @ #vk.2 )
    case Wallet_Send_Deferred_Req___VARIANT_1
    solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
      case CI_Publish_RequestEncKey
      solve( !CI_PendingTx_Fixed( $CI, tid,
                                  aToken(~atSecret, pk(~skDPoP), $CI, $AS), $AS.1, $Wid_at, pk(~skDPoP),
                                  pkH, pk(~skB)
             ) ▶₂ #i )
        case CI_Credential_Endpoint_Defer___VARIANT_4
        solve( !Ltk_CI( $CI, ~ltkCI ) ▶₃ #i )
          case Register_CI
          solve( !KU( penc(<'202-deferred', ~tid_ci>, pk(~skE_W), rRespEnc.1)
                 ) @ #vk.3 )
            case CI_Credential_Endpoint_Defer___VARIANT_4
            solve( !KU( penc(<'credential-req-fixed', 
                              aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                              sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), jti_c.1, 
                                    aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                   ~skDPoP), 
                              pk(skH_x), 
                              sign(<'openid4vci-proof+jwt', 'ES256', pk(skH_x), $CI, iat.1>, skH_x), 
                              'crypt-resp', pk(~skE_W), 'tid-bind', pk(~skB)>,
                             pk(~skR_CI), rEnc.2)
                   ) @ #vk.6 )
              case Wallet_Send_Credential_Req___VARIANT_1
              by contradiction /* from formulas */
            next
              case c_penc
              by contradiction /* from formulas */
            qed
          next
            case c_penc
            solve( !KU( pk(~skE_W) ) @ #vk.8 )
              case Wallet_Send_Credential_Req___VARIANT_1
              by contradiction /* from formulas */
            next
              case Wallet_Send_Deferred_Req___VARIANT_1
              by contradiction /* cyclic */
            next
              case c_pk
              solve( !KU( penc(<'credential-req-fixed', 
                                aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                                sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), jti_c.1, 
                                      aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                     ~skDPoP), 
                                pk(skH_x), 
                                sign(<'openid4vci-proof+jwt', 'ES256', pk(skH_x), $CI, iat.1>, skH_x), 
                                'crypt-resp', pkE_W, 'tid-bind', pk(~skB)>,
                               pk(~skR_CI), rEnc.2)
                     ) @ #vk.7 )
                case Wallet_Send_Credential_Req___VARIANT_1
                by contradiction /* from formulas */
              next
                case c_penc
                by contradiction /* from formulas */
              qed
            qed
          qed
        qed
      qed
    qed
  next
    case c_penc
    solve( !KU( pk(~skR_CI) ) @ #vk.4 )
      case CI_Publish_RequestEncKey
      solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
        case CI_Publish_RequestEncKey
        solve( !CI_PendingTx_Fixed( $CI, tid, AT, $AS, $Wid_at, pk(skDPoP_x),
                                    pkH, pk(skB_x)
               ) ▶₂ #i )
          case CI_Credential_Endpoint_Defer___VARIANT_4
          solve( !Ltk_CI( $CI, ~ltkCI ) ▶₃ #i )
            case Register_CI
            solve( !KU( sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP), 
                              jti_d, aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                             ~skDPoP)
                   ) @ #vk.10 )
              case Wallet_Send_Deferred_Req___VARIANT_1
              by contradiction /* from formulas */
            next
              case c_sign
              solve( !KU( pk(~skDPoP) ) @ #vk.34 )
                case c_pk
                solve( !KU( sign(<'oid4vci-tid-bind', $CI, ~tid_ci, h(pkE_new)>, skB_x)
                       ) @ #vk.22 )
                  case Wallet_Send_Deferred_Req___VARIANT_1
                  by contradiction /* from formulas */
                next
                  case c_sign
                  solve( !KU( penc(<'credential-req-fixed', 
                                    aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                                    sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), jti_c, 
                                          aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                         ~skDPoP), 
                                    pk(skH_x), 
                                    sign(<'openid4vci-proof+jwt', 'ES256', pk(skH_x), $CI, iat>, skH_x), 
                                    'crypt-resp', pkE_W, 'tid-bind', pk(skB_x)>,
                                   pk(~skR_CI), rEnc.1)
                         ) @ #vk.27 )
                    case Wallet_Send_Credential_Req___VARIANT_1
                    by contradiction /* from formulas */
                  next
                    case c_penc
                    by contradiction /* from formulas */
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    next
      case Register_CI
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case Wallet_Send_Credential_Req___VARIANT_1_case_1
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case Wallet_Send_Credential_Req___VARIANT_1_case_2
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case Wallet_Send_Credential_Req___VARIANT_1_case_3
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case Wallet_Send_Deferred_Req___VARIANT_1
      by solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
    next
      case c_pk
      solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
        case CI_Publish_RequestEncKey
        by contradiction /* from formulas */
      qed
    qed
  qed
qed

lemma c2prime_attack_witness_fixed [heuristic={c2prime_witness_tactic}]:
  exists-trace
  "∃ CI AS WidA WidB pkH_A pkH_B cred AT tid pkE_Adv pkB_Adv pkD sidA sidB
     #wA #wB #i #k #r_at #r_dp #r_h.
    ((((((((((((((((((Wallet_Sent_Cred_Req( WidA, CI, sidA, pkH_A, AT
                      ) @ #wA) ∧
                     (WalletGen_HolderKey( WidB, sidB, pkH_B ) @ #wB)) ∧
                    (CI_Issued_Credential_Fixed( CI, AS, WidA, pkH_B, cred, AT, tid, pkE_Adv,
                                                 pkB_Adv
                     ) @ #i)) ∧
                   (K( cred ) @ #k)) ∧
                  (Reveal_StoredAT( WidA, CI, AT ) @ #r_at)) ∧
                 (Reveal_DPoPKey( WidA, pkD ) @ #r_dp)) ∧
                (Reveal_HolderKey( WidB, pkH_B ) @ #r_h)) ∧
               (¬(WidA = WidB))) ∧
              (#wA < #r_at)) ∧
             (#wB < #r_h)) ∧
            (#r_at < #i)) ∧
           (#r_dp < #i)) ∧
          (#r_h < #i)) ∧
         (#i < #k)) ∧
        (¬(∃ #r. Reveal_CI( CI ) @ #r))) ∧
       (¬(∃ #r. Reveal_CI_ReqEncKey( CI ) @ #r))) ∧
      (¬(∃ p #r. Reveal_WalletBindKey( WidA, p ) @ #r))) ∧
     (¬(∃ p #r. Reveal_HolderKey( WidA, p ) @ #r))) ∧
    (¬(∃ p #r. Reveal_WalletEncKey( WidA, p ) @ #r))"
/*
guarded formula characterizing all satisfying traces:
"∃ CI AS WidA WidB pkH_A pkH_B cred AT tid pkE_Adv pkB_Adv pkD sidA sidB
   #wA #wB #i #k #r_at #r_dp #r_h.
  (Wallet_Sent_Cred_Req( WidA, CI, sidA, pkH_A, AT ) @ #wA) ∧
  (WalletGen_HolderKey( WidB, sidB, pkH_B ) @ #wB) ∧
  (CI_Issued_Credential_Fixed( CI, AS, WidA, pkH_B, cred, AT, tid, pkE_Adv,
                               pkB_Adv
   ) @ #i) ∧
  (K( cred ) @ #k) ∧
  (Reveal_StoredAT( WidA, CI, AT ) @ #r_at) ∧
  (Reveal_DPoPKey( WidA, pkD ) @ #r_dp) ∧
  (Reveal_HolderKey( WidB, pkH_B ) @ #r_h)
 ∧
  (¬(WidA = WidB)) ∧
  (#wA < #r_at) ∧
  (#wB < #r_h) ∧
  (#r_at < #i) ∧
  (#r_dp < #i) ∧
  (#r_h < #i) ∧
  (#i < #k) ∧
  (∀ #r. (Reveal_CI( CI ) @ #r) ⇒ ⊥) ∧
  (∀ #r. (Reveal_CI_ReqEncKey( CI ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_WalletBindKey( WidA, p ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_HolderKey( WidA, p ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_WalletEncKey( WidA, p ) @ #r) ⇒ ⊥)"
*/
simplify
solve( CI_Issued_Credential_Fixed( $CI, AS.2, $Wid, pk(~skH.1), cred, AT,
                                   tid, pkE_Adv, pkB_Adv
       ) @ #i )
  case CI_Deferred_Endpoint_Fixed___VARIANT_4
  solve( !StoredAT( $Wid, $CI, AT ) ▶₀ #r_at )
    case Wallet_Get_AT
    solve( !StoredDPoPKey( $Wid, ~skDPoP.1, pkD ) ▶₀ #r_dp )
      case Wallet_Get_AT
      solve( !StoredHolderKey( $Wid.1, ~skH.1, pk(~skH) ) ▶₀ #r_h )
        case Wallet_Send_Credential_Req___VARIANT_1
        solve( !CI_PendingTx_Fixed( $CI, tid,
                                    aToken(~atSecret, pk(~skDPoP), $CI, $AS), $AS.1, $Wid, pk(skDPoP_x),
                                    pk(~skH), pk(skB_x)
               ) ▶₂ #i )
          case CI_Credential_Endpoint_Defer___VARIANT_4
          solve( W_HasAT( $Wid, $CI, $AS.1, ~sid.1,
                          aToken(~atSecret, pk(~skDPoP), $CI, $AS), ~skDPoP.2, pkDPoP
                 ) ▶₀ #wA )
            case Wallet_Get_AT
            solve( !CI_ReqEncPk( $CI, pkR_CI ) ▶₁ #wA )
              case CI_Publish_RequestEncKey
              solve( !KU( penc(<'def-req-fixed', 
                                aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                                sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP), jti_d, 
                                      aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                     ~skDPoP), 
                                ~tid_ci, 'crypt-resp', pkE_Adv, 'tid-bind-sig', 
                                sign(<'oid4vci-tid-bind', $CI, ~tid_ci, h(pkE_Adv)>, skB_x)>,
                               pk(~skR_CI), rEnc)
                     ) @ #vk.3 )
                case c_penc
                solve( !CI_ReqEncSk( $CI, ~skR_CI ) ▶₁ #i )
                  case CI_Publish_RequestEncKey
                  solve( !Ltk_CI( $CI, ~ltkCI ) ▶₃ #i )
                    case Register_CI
                    solve( !KU( sign(<'credential', $CI, 'PII-dataset', pk(~skH)>, ~ltkCI)
                           ) @ #vk.2 )
                      case CI_Deferred_Endpoint_Fixed___VARIANT_4
                      solve( !KU( penc(<'credential-req-fixed', 
                                        aToken(~atSecret, pk(~skDPoP), $CI, $AS), 
                                        sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), jti_c.2, 
                                              aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                             ~skDPoP), 
                                        pk(~skH), 
                                        sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, iat.2>, ~skH), 
                                        'crypt-resp', pkE_W, 'tid-bind', pk(skB_x)>,
                                       pk(~skR_CI), rEnc.3)
                             ) @ #vk.8 )
                        case c_penc
                        solve( !KU( pk(~skR_CI) ) @ #vk.10 )
                          case CI_Publish_RequestEncKey
                          solve( !KU( aToken(~atSecret, pk(~skDPoP), $CI, $AS) ) @ #vk.14 )
                            case Reveal_StoredAT_Rule
                            solve( !KU( sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP), 
                                              jti_d, aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                             ~skDPoP)
                                   ) @ #vk.18 )
                              case c_sign
                              solve( !KU( sign(<'oid4vci-tid-bind', $CI, ~tid_ci, h(pkE_Adv)>, skB_x)
                                     ) @ #vk.32 )
                                case c_sign
                                solve( !KU( penc(<'def-req-fixed', 
                                                  aToken(~atSecret.3, pk(~skDPoP.3), $CI, $AS.3), 
                                                  sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP.3), 
                                                        jti_d.1, 
                                                        aToken(~atSecret.3, pk(~skDPoP.3), $CI, $AS.3)>,
                                                       ~skDPoP.3), 
                                                  ~tid_ci.1, 'crypt-resp', pk(k.1), 'tid-bind-sig', 
                                                  sign(<'oid4vci-tid-bind', $CI, ~tid_ci.1, h(pk(k.1))>,
                                                       skB_x.1)
                                                 >,
                                                 pk(~skR_CI), rEnc.4)
                                       ) @ #vk.35 )
                                  case Wallet_Send_Deferred_Req___VARIANT_1
                                  solve( !KU( penc(<'credential-req-fixed', 
                                                    aToken(~atSecret.3, pk(~skDPoP.3), $CI, $AS.3), 
                                                    sign(<'dpop+jwt', $CI, 'POST', 'credential', 
                                                          pk(~skDPoP.3), jti_c.3, 
                                                          aToken(~atSecret.3, pk(~skDPoP.3), $CI, $AS.3)>,
                                                         ~skDPoP.3), 
                                                    pk(~skH), 
                                                    sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, 
                                                          iat.3>,
                                                         ~skH), 
                                                    'crypt-resp', pkE_W.1, 'tid-bind', pk(~skB.2)>,
                                                   pk(~skR_CI), rEnc.5)
                                         ) @ #vk.39 )
                                    case Wallet_Send_Credential_Req___VARIANT_1
                                    solve( !KU( sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP), 
                                                      jti_c.2, aToken(~atSecret, pk(~skDPoP), $CI, $AS)>,
                                                     ~skDPoP)
                                           ) @ #vk.44 )
                                      case c_sign
                                      solve( !KU( pk(~skH) ) @ #vk.47 )
                                        case c_pk
                                        solve( !StoredHolderKey( $Wid_at, ~skH.2, pk(~skH) ) ▶₀ #l.1 )
                                          case Wallet_Send_Credential_Req___VARIANT_1
                                          solve( !KU( sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, 
                                                            iat.2>,
                                                           ~skH)
                                                 ) @ #vk.52 )
                                            case c_sign
                                            solve( !StoredHolderKey( $Wid_at, ~skH.2, pk(~skH) ) ▶₀ #l.2 )
                                              case Wallet_Send_Credential_Req___VARIANT_1
                                              solve( !KU( pk(skB_x) ) @ #vk.61 )
                                                case CI_Publish_RequestEncKey
                                                solve( !KU( pk(~skDPoP) ) @ #vk.70 )
                                                  case c_pk
                                                  solve( !KU( h(pkE_Adv) ) @ #vk.74 )
                                                    case c_h
