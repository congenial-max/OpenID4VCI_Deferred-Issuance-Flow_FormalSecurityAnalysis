lemma skR_CI_secrecy [reuse, use_induction]:
  all-traces
  "∀ CI skR #r #i.
    ((CIReqEncSk( CI, skR ) @ #r) ∧ (!KU( skR ) @ #i)) ⇒
    (∃ #l. (Reveal_CI_ReqEncKey( CI ) @ #l) ∧ (#l < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ CI skR #r #i.
  (CIReqEncSk( CI, skR ) @ #r) ∧ (!KU( skR ) @ #i)
 ∧
  ∀ #l. (Reveal_CI_ReqEncKey( CI ) @ #l) ⇒ ¬(#l < #i)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i))  ∥ (last(#r))  ∥
         (∃ #l. (Reveal_CI_ReqEncKey( $CI ) @ #l) ∧ (¬(last(#l))) ∧ (#l < #i)) )
    case case_1
    solve( !Ltk_CI( $CI, ~ltkCI ) ▶₁ #r )
      case Register_CI
      solve( !KU( ~skR_CI ) @ #i )
        case Reveal_CI_ReqEncKey_Rule
        by contradiction /* from formulas */
      qed
    qed
  next
    case case_2
    solve( !Ltk_CI( $CI, ~ltkCI ) ▶₁ #r )
      case Register_CI
      solve( !KU( ~skR_CI ) @ #i )
        case Reveal_CI_ReqEncKey_Rule
        by contradiction /* from formulas */
      qed
    qed
  next
    case case_3
    by contradiction /* from formulas */
  qed
qed

lemma ltkCI_secrecy [reuse, use_induction]:
  all-traces
  "∀ CI k #r #i.
    ((CIKey( CI, k ) @ #r) ∧ (!KU( k ) @ #i)) ⇒
    (∃ #l. (Reveal_CI( CI ) @ #l) ∧ (#l < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ CI k #r #i.
  (CIKey( CI, k ) @ #r) ∧ (!KU( k ) @ #i)
 ∧
  ∀ #l. (Reveal_CI( CI ) @ #l) ⇒ ¬(#l < #i)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i))  ∥ (last(#r))  ∥
         (∃ #l. (Reveal_CI( $CI ) @ #l) ∧ (¬(last(#l))) ∧ (#l < #i)) )
    case case_1
    solve( !KU( ~ltkCI ) @ #i )
      case Reveal_CI_Ltk
      by contradiction /* from formulas */
    qed
  next
    case case_2
    solve( !KU( ~ltkCI ) @ #i )
      case Reveal_CI_Ltk
      by contradiction /* from formulas */
    qed
  next
    case case_3
    by contradiction /* from formulas */
  qed
qed

lemma skH_secrecy [reuse, use_induction]:
  all-traces
  "∀ Wid skH pkH #r #i.
    ((HolderKeyFresh( Wid, skH, pkH ) @ #r) ∧ (!KU( skH ) @ #i)) ⇒
    (∃ #l. (Reveal_HolderKey( Wid, pkH ) @ #l) ∧ (#l < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ Wid skH pkH #r #i.
  (HolderKeyFresh( Wid, skH, pkH ) @ #r) ∧ (!KU( skH ) @ #i)
 ∧
  ∀ #l. (Reveal_HolderKey( Wid, pkH ) @ #l) ⇒ ¬(#l < #i)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i))  ∥ (last(#r))  ∥
         (∃ #l.
           (Reveal_HolderKey( $Wid, pk(~skH) ) @ #l) ∧ (¬(last(#l))) ∧ (#l < #i)) )
    case case_1
    solve( !KU( ~skH ) @ #i )
      case Reveal_HolderKey_Rule
      by contradiction /* from formulas */
    qed
  next
    case case_2
    solve( !KU( ~skH ) @ #i )
      case Reveal_HolderKey_Rule
      by contradiction /* from formulas */
    qed
  next
    case case_3
    by contradiction /* from formulas */
  qed
qed

lemma skE_W_secrecy [reuse, use_induction]:
  all-traces
  "∀ Wid skE pkE #r #i.
    ((EncKeyFresh( Wid, skE, pkE ) @ #r) ∧ (!KU( skE ) @ #i)) ⇒
    (∃ #l. (Reveal_WalletEncKey( Wid, pkE ) @ #l) ∧ (#l < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ Wid skE pkE #r #i.
  (EncKeyFresh( Wid, skE, pkE ) @ #r) ∧ (!KU( skE ) @ #i)
 ∧
  ∀ #l. (Reveal_WalletEncKey( Wid, pkE ) @ #l) ⇒ ¬(#l < #i)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i))  ∥ (last(#r))  ∥
         (∃ #l.
           (Reveal_WalletEncKey( $Wid, pk(~skE_W) ) @ #l)
          ∧
           (¬(last(#l))) ∧ (#l < #i)) )
    case case_1
    solve( W_HasAT_V3( $Wid, $CI, $AS, ~sid, AT, ~skDPoP, pkDPoP, ~skH, pkH
           ) ▶₀ #r )
      case Wallet_Get_AT
      solve( !CI_ReqEncPk( $CI, pkR_CI ) ▶₁ #r )
        case CI_Publish_RequestEncKey
        solve( !KU( ~skE_W ) @ #i )
          case Reveal_WalletEncKey_Rule
          by contradiction /* from formulas */
        qed
      qed
    qed
  next
    case case_2
    solve( W_HasAT_V3( $Wid, $CI, $AS, ~sid, AT, ~skDPoP, pkDPoP, ~skH, pkH
           ) ▶₀ #r )
      case Wallet_Get_AT
      solve( !CI_ReqEncPk( $CI, pkR_CI ) ▶₁ #r )
        case CI_Publish_RequestEncKey
        solve( !KU( ~skE_W ) @ #i )
          case Reveal_WalletEncKey_Rule
          by contradiction /* from formulas */
        qed
      qed
    qed
  next
    case case_3
    by contradiction /* from formulas */
  qed
qed

lemma helper_pkH_unique [reuse, use_induction]:
  all-traces
  "∀ Wid1 Wid2 s1 s2 pkH #i #j.
    ((WalletGen_HolderKey( Wid1, s1, pkH ) @ #i) ∧
     (WalletGen_HolderKey( Wid2, s2, pkH ) @ #j)) ⇒
    (#i = #j)"
/*
guarded formula characterizing all counter-examples:
"∃ Wid1 Wid2 s1 s2 pkH #i #j.
  (WalletGen_HolderKey( Wid1, s1, pkH ) @ #i) ∧
  (WalletGen_HolderKey( Wid2, s2, pkH ) @ #j)
 ∧
  ¬(#i = #j)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  by contradiction /* from formulas */
qed

