lemma P10_credential_secrecy_fixed:
  all-traces
  "∀ CI AS Wid pkH cred AT tid pkE_new pkB sid #i #g.
    (((((((CI_Issued_Credential_Fixed( CI, AS, Wid, pkH, cred, AT, tid,
                                       pkE_new, pkB
           ) @ #i) ∧
          (WalletGen_HolderKey( Wid, sid, pkH ) @ #g)) ∧
         (¬(∃ #r. Reveal_CI( CI ) @ #r))) ∧
        (¬(∃ #r. Reveal_CI_ReqEncKey( CI ) @ #r))) ∧
       (¬(∃ p #r. Reveal_HolderKey( Wid, p ) @ #r))) ∧
      (¬(∃ p #r. Reveal_WalletEncKey( Wid, p ) @ #r))) ∧
     (¬(∃ p #r. Reveal_WalletBindKey( Wid, p ) @ #r))) ⇒
    (¬(∃ #k. K( cred ) @ #k))"
/*
guarded formula characterizing all counter-examples:
"∃ CI AS Wid pkH cred AT tid pkE_new pkB sid #i #g.
  (CI_Issued_Credential_Fixed( CI, AS, Wid, pkH, cred, AT, tid, pkE_new,
                               pkB
   ) @ #i) ∧
  (WalletGen_HolderKey( Wid, sid, pkH ) @ #g)
 ∧
  (∀ #r. (Reveal_CI( CI ) @ #r) ⇒ ⊥) ∧
  (∀ #r. (Reveal_CI_ReqEncKey( CI ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_HolderKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_WalletEncKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∀ p #r. (Reveal_WalletBindKey( Wid, p ) @ #r) ⇒ ⊥) ∧
  (∃ #k. (K( cred ) @ #k))"
*/
simplify
solve( W_HasAT( $Wid, $CI, $AS, ~sid, AT, ~skDPoP, pkDPoP ) ▶₀ #g )
  case Wallet_Get_AT
  solve( !CI_ReqEncPk( $CI, pkR_CI ) ▶₁ #g )
    case CI_Publish_RequestEncKey
    solve( CI_Issued_Credential_Fixed( CI.1, AS.1, $Wid, pk(~skH), cred, AT,
                                       tid, pkE_new, pkB
           ) @ #i )
      case CI_Deferred_Endpoint_Fixed___VARIANT_4
      solve( !CI_ReqEncSk( $CI.1, ~skR_CI.1 ) ▶₁ #i )
        case CI_Publish_RequestEncKey
        solve( !CI_PendingTx_Fixed( $CI.1, tid, AT, $AS.1, $Wid, pk(skDPoP_x),
                                    pk(~skH), pk(skB_x)
               ) ▶₂ #i )
          case CI_Credential_Endpoint_Defer___VARIANT_4
          solve( !Ltk_CI( $CI.1, ~ltkCI ) ▶₃ #i )
            case Register_CI
            solve( !KU( sign(<'credential', $CI.1, 'PII-dataset', pk(~skH)>, ~ltkCI)
                   ) @ #vk )
              case CI_Deferred_Endpoint_Fixed___VARIANT_4
              solve( !KU( penc(<'def-req-fixed', 
                                aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1), 
                                sign(<'dpop+jwt', $CI.1, 'POST', 'deferred', pk(~skDPoP.1), jti_d, 
                                      aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1)>,
                                     ~skDPoP.1), 
                                ~tid_ci, 'crypt-resp', pkE_new, 'tid-bind-sig', 
                                sign(<'oid4vci-tid-bind', $CI.1, ~tid_ci, h(pkE_new)>, skB_x)>,
                               pk(~skR_CI.1), rEnc.1)
                     ) @ #vk.4 )
                case Wallet_Send_Deferred_Req___VARIANT_1
                solve( !KU( penc(<'credential-req-fixed', 
                                  aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1), 
                                  sign(<'dpop+jwt', $CI.1, 'POST', 'credential', pk(~skDPoP.1), jti_c.1, 
                                        aToken(~atSecret.1, pk(~skDPoP.1), $CI.1, $AS.1)>,
                                       ~skDPoP.1), 
                                  pk(~skH), 
                                  sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI.1, iat.1>, ~skH), 
                                  'crypt-resp', pkE_W, 'tid-bind', pk(~skB.1)>,
                                 pk(~skR_CI.1), rEnc.2)
                       ) @ #vk.8 )
                  case Wallet_Send_Credential_Req___VARIANT_1
                  solve( !KU( penc(<'def-req-fixed', 
                                    aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1), 
                                    sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP.1), jti_d.1, 
                                          aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                                         ~skDPoP.1), 
                                    ~tid_ci.1, 'crypt-resp', pk(k.1), 'tid-bind-sig', 
                                    sign(<'oid4vci-tid-bind', $CI, ~tid_ci.1, h(pk(k.1))>, skB_x)>,
                                   pk(~skR_CI), rEnc.2)
                         ) @ #vk.9 )
                    case Wallet_Send_Deferred_Req___VARIANT_1
                    solve( !StoredWalletEncKey( $Wid_at, ~skE, pk(~skE_W.1) ) ▶₀ #l )
                      case Wallet_Send_Credential_Req___VARIANT_1
                      solve( !KU( penc(<'credential-req-fixed', 
                                        aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1), 
                                        sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP.1), jti_c.1, 
                                              aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                                             ~skDPoP.1), 
                                        pk(~skH), 
                                        sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, iat.1>, ~skH), 
                                        'crypt-resp', pkE_W, 'tid-bind', pk(~skB.1)>,
                                       pk(~skR_CI), rEnc.3)
                             ) @ #vk.11 )
                        case Wallet_Send_Credential_Req___VARIANT_1
                        by contradiction /* from formulas */
                      next
                        case c_penc
                        solve( !KU( aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1) ) @ #vk.19 )
                          case Reveal_StoredAT_Rule
                          solve( !KU( sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP.1), 
                                            jti_c.1, aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                                           ~skDPoP.1)
                                 ) @ #vk.21 )
                            case Wallet_Send_Credential_Req___VARIANT_1
                            by contradiction /* from formulas */
                          next
                            case c_sign
                            solve( !KU( ~skDPoP.1 ) @ #vk.35 )
                              case Reveal_DPoPKey_Rule
                              solve( !KU( sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, iat.1>,
                                               ~skH)
                                     ) @ #vk.28 )
                                case Wallet_Send_Credential_Req___VARIANT_1
                                by contradiction /* from formulas */
                              next
                                case c_sign
                                by contradiction /* from formulas */
                              qed
                            qed
                          qed
                        next
                          case Wallet_Send_Credential_Req___VARIANT_1
                          by contradiction /* from formulas */
                        next
                          case Wallet_Send_Deferred_Req___VARIANT_1
                          by contradiction /* cyclic */
                        qed
                      qed
                    qed
                  next
                    case c_penc
                    solve( !KU( aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1) ) @ #vk.18 )
                      case Reveal_StoredAT_Rule
                      solve( !KU( ~tid_ci.1 ) @ #vk.22 )
                        case CI_Credential_Endpoint_Defer___VARIANT_4
                        solve( !KU( sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP.1), 
                                          jti_d.1, aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                                         ~skDPoP.1)
                               ) @ #vk.21 )
                          case Wallet_Send_Deferred_Req___VARIANT_1
                          by contradiction /* from formulas */
                        next
                          case c_sign
                          solve( !KU( ~skDPoP.1 ) @ #vk.33 )
                            case Reveal_DPoPKey_Rule
                            solve( !KU( sign(<'oid4vci-tid-bind', $CI, ~tid_ci.1, h(pk(k.1))>, skB_x)
                                   ) @ #vk.32 )
                              case Wallet_Send_Deferred_Req___VARIANT_1
                              by contradiction /* from formulas */
                            next
                              case c_sign
                              solve( !KU( penc(<'credential-req-fixed', 
                                                aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1), 
                                                sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP.1), 
                                                      jti_c.1, aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)
                                                     >,
                                                     ~skDPoP.1), 
                                                pk(~skH), 
                                                sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, iat.1>,
                                                     ~skH), 
                                                'crypt-resp', pk(k.2), 'tid-bind', pk(skB_x)>,
                                               pk(~skR_CI), rEnc.3)
                                     ) @ #vk.24 )
                                case c_penc
                                solve( !KU( sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP.1), 
                                                  jti_c.1, aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                                                 ~skDPoP.1)
                                       ) @ #vk.56 )
                                  case Wallet_Send_Credential_Req___VARIANT_1
                                  by contradiction /* from formulas */
                                next
                                  case c_sign
                                  solve( !KU( sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, iat.1>,
                                                   ~skH)
                                         ) @ #vk.65 )
                                    case Wallet_Send_Credential_Req___VARIANT_1
                                    by contradiction /* from formulas */
                                  next
                                    case c_sign
                                    by contradiction /* from formulas */
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      next
                        case Reveal_TxId_Rule
                        solve( !KU( sign(<'dpop+jwt', $CI, 'POST', 'deferred', pk(~skDPoP.1), 
                                          jti_d.1, aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                                         ~skDPoP.1)
                               ) @ #vk.21 )
                          case Wallet_Send_Deferred_Req___VARIANT_1
                          by contradiction /* from formulas */
                        next
                          case c_sign
                          solve( !KU( ~skDPoP.1 ) @ #vk.32 )
                            case Reveal_DPoPKey_Rule
                            solve( !KU( sign(<'oid4vci-tid-bind', $CI, ~tid_ci.1, h(pk(k.1))>, skB_x)
                                   ) @ #vk.32 )
                              case Wallet_Send_Deferred_Req___VARIANT_1
                              by contradiction /* from formulas */
                            next
                              case c_sign
                              solve( !KU( penc(<'credential-req-fixed', 
                                                aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1), 
                                                sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP.1), 
                                                      jti_c.1, aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)
                                                     >,
                                                     ~skDPoP.1), 
                                                pk(~skH), 
                                                sign(<'openid4vci-proof+jwt', 'ES256', pk(~skH), $CI, iat.1>,
                                                     ~skH), 
                                                'crypt-resp', pkE_W, 'tid-bind', pk(skB_x)>,
                                               pk(~skR_CI), rEnc.3)
                                     ) @ #vk.24 )
                                case c_penc
                                solve( !KU( sign(<'dpop+jwt', $CI, 'POST', 'credential', pk(~skDPoP.1), 
                                                  jti_c.1, aToken(~atSecret.1, pk(~skDPoP.1), $CI, $AS.1)>,
                                                 ~skDPoP.1)
                                       ) @ #vk.55 )
